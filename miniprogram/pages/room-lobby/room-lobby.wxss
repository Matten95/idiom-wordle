.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: calc(92rpx + env(safe-area-inset-top)) 30rpx 46rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 14% 7%, rgba(255, 218, 142, 0.5) 0, rgba(255, 218, 142, 0) 190rpx),
    radial-gradient(circle at 88% 12%, rgba(108, 167, 225, 0.4) 0, rgba(108, 167, 225, 0) 210rpx),
    linear-gradient(180deg, #eaf4ff 0%, #f8efe0 54%, #eaf2ff 100%);
  color: #18213d;
}

.header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  width: 100%;
  max-width: 650rpx;
  margin: 0 auto 18rpx;
  padding: 14rpx 16rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  background: rgba(30, 75, 135, 0.16);
  box-shadow: 0 12rpx 30rpx rgba(26, 63, 120, 0.1);
  backdrop-filter: blur(12rpx);
  box-sizing: border-box;
}

.header-back {
  width: 118rpx;
  flex-shrink: 0;
  color: #315fb5;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.2;
}

.header-title {
  flex: 1;
  min-width: 0;
  color: #18213d;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.2;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.header-spacer {
  width: 118rpx;
  flex-shrink: 0;
}

.mode-intro {
  position: relative;
  width: 100%;
  max-width: 650rpx;
  margin: 0 auto 18rpx;
  padding: 24rpx 28rpx 24rpx 104rpx;
  border-radius: 22rpx;
  border: 2rpx solid rgba(240, 166, 65, 0.28);
  background: linear-gradient(180deg, rgba(255, 252, 242, 0.98) 0%, rgba(255, 238, 202, 0.96) 100%);
  color: #59647a;
  font-size: 25rpx;
  line-height: 1.35;
  text-align: left;
  box-shadow: 0 18rpx 38rpx rgba(151, 97, 28, 0.13);
  box-sizing: border-box;
}

.mode-intro::before {
  content: '战';
  position: absolute;
  left: 24rpx;
  top: 50%;
  width: 58rpx;
  height: 58rpx;
  border-radius: 16rpx;
  background: #e45b58;
  color: #fff9ee;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
  transform: translateY(-50%) rotate(-5deg);
}

.room-steps {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  width: 100%;
  max-width: 650rpx;
  margin: 0 auto 18rpx;
}

.room-step {
  min-width: 0;
  min-height: 92rpx;
  padding: 14rpx 8rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  background: rgba(255, 255, 255, 0.74);
  box-shadow: 0 10rpx 22rpx rgba(28, 57, 112, 0.07);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-sizing: border-box;
}

.room-step-icon {
  width: 42rpx;
  height: 42rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #315fb5 0%, #f0a641 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 900;
  flex-shrink: 0;
}

.room-step-text {
  color: #18213d;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.2;
}

.room-social-card {
  width: 100%;
  max-width: 650rpx;
  margin: 0 auto 18rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  background: rgba(255, 255, 255, 0.78);
  box-shadow: 0 12rpx 28rpx rgba(28, 57, 112, 0.08);
  backdrop-filter: blur(10rpx);
  display: grid;
  grid-template-columns: minmax(0, 1fr) 58rpx minmax(0, 1fr);
  align-items: center;
  gap: 10rpx;
  box-sizing: border-box;
}

.social-player {
  min-width: 0;
  min-height: 86rpx;
  padding: 12rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-sizing: border-box;
}

.social-player.ready {
  background: linear-gradient(180deg, #ffffff 0%, #eef8f5 100%);
  border: 1rpx solid rgba(35, 133, 109, 0.18);
}

.social-player.waiting {
  background: linear-gradient(180deg, #ffffff 0%, #fff3d7 100%);
  border: 1rpx solid rgba(240, 166, 65, 0.24);
}

.social-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #315fb5 0%, #f0a641 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 900;
  flex-shrink: 0;
}

.social-copy {
  min-width: 0;
}

.social-name,
.social-state {
  display: block;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.social-name {
  color: #18213d;
  font-size: 23rpx;
  font-weight: 900;
}

.social-state {
  margin-top: 6rpx;
  color: #59647a;
  font-size: 20rpx;
}

.social-vs {
  width: 58rpx;
  height: 58rpx;
  border-radius: 18rpx;
  color: #fff9ee;
  background: #e45b58;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 900;
  transform: rotate(5deg);
  box-shadow: 0 8rpx 18rpx rgba(228, 91, 88, 0.18);
}

.mode-tabs {
  display: flex;
  width: 100%;
  max-width: 650rpx;
  margin-bottom: 20rpx;
  padding: 6rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 18rpx;
  box-sizing: border-box;
}

.mode-tab {
  flex: 1;
  min-height: 88rpx;
  border-radius: 14rpx;
  color: #59647a;
  font-size: 28rpx;
  line-height: 88rpx;
  text-align: center;
  transition: background 0.2s, color 0.2s;
}

.mode-tab.active {
  background: linear-gradient(135deg, #e45b58 0%, #f0a641 100%);
  color: #ffffff;
  font-weight: 700;
  box-shadow: 0 10rpx 20rpx rgba(228, 91, 88, 0.18);
}

.card {
  width: 100%;
  max-width: 650rpx;
  padding: 34rpx 30rpx;
  margin: 0 auto 20rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(240, 166, 65, 0.28);
  background: linear-gradient(180deg, rgba(255, 252, 242, 0.98) 0%, rgba(255, 238, 202, 0.96) 100%);
  box-shadow: 0 22rpx 46rpx rgba(151, 97, 28, 0.15);
  box-sizing: border-box;
}

.card-title {
  color: #18213d;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.25;
  margin-bottom: 24rpx;
}

.label {
  color: #59647a;
  font-size: 24rpx;
  line-height: 1.25;
  margin-bottom: 12rpx;
}

.round-options {
  display: flex;
  gap: 14rpx;
  margin-bottom: 30rpx;
}

.round-note {
  margin: -12rpx 0 26rpx;
  color: #9a621e;
  font-size: 22rpx;
  line-height: 1.35;
  text-align: center;
}

.round-opt {
  flex: 1;
  min-height: 82rpx;
  border-radius: 18rpx;
  border: 2rpx solid rgba(240, 166, 65, 0.22);
  color: #59647a;
  background: rgba(255, 255, 255, 0.62);
  font-size: 28rpx;
  line-height: 82rpx;
  text-align: center;
  box-sizing: border-box;
  transition: background 0.2s, border-color 0.2s;
}

.round-opt.selected {
  border-color: rgba(228, 91, 88, 0.42);
  color: #e45b58;
  background: #fff3d7;
  font-weight: 700;
}

.btn-primary {
  width: 100%;
  min-height: 92rpx;
  padding: 0;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #e45b58 0%, #f0a641 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 92rpx;
  text-align: center;
  border: none;
  box-shadow: 0 16rpx 30rpx rgba(228, 91, 88, 0.22);
}

.btn-primary::after {
  border: none;
}

.btn-primary[disabled] {
  background: rgba(255, 255, 255, 0.58);
  color: rgba(89, 100, 122, 0.58);
  border: 1rpx solid rgba(240, 166, 65, 0.18);
  box-shadow: none;
}

.code-input {
  width: 100%;
  height: 100rpx;
  margin-bottom: 30rpx;
  border-radius: 18rpx;
  border: 2rpx solid rgba(240, 166, 65, 0.42);
  background: rgba(255, 255, 255, 0.82);
  color: #18213d;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 100rpx;
  text-align: center;
  letter-spacing: 0;
  box-sizing: border-box;
}

.error-msg {
  width: 100%;
  max-width: 650rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 20rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(228, 91, 88, 0.24);
  background: linear-gradient(180deg, #fff8f0 0%, #fff0ef 100%);
  box-shadow: 0 12rpx 28rpx rgba(228, 91, 88, 0.1);
  display: flex;
  align-items: center;
  gap: 14rpx;
  box-sizing: border-box;
}

.error-badge {
  width: 52rpx;
  height: 52rpx;
  border-radius: 16rpx;
  background: #e45b58;
  color: #fff9ee;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
  flex-shrink: 0;
  transform: rotate(-4deg);
}

.error-copy {
  flex: 1;
  min-width: 0;
}

.error-title,
.error-text {
  display: block;
  line-height: 1.35;
}

.error-title {
  color: #9a621e;
  font-size: 22rpx;
  font-weight: 900;
  margin-bottom: 3rpx;
}

.error-text {
  color: #e45b58;
  font-size: 24rpx;
}

.waiting-card {
  text-align: center;
}

.waiting-icon {
  width: 68rpx;
  height: 68rpx;
  margin: 0 auto 12rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  background: #e45b58;
  color: #fff9ee;
  font-size: 28rpx;
  line-height: 68rpx;
}

.waiting-title {
  color: #18213d;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.25;
  margin-bottom: 8rpx;
}

.waiting-subtitle {
  color: #59647a;
  font-size: 24rpx;
  line-height: 1.4;
  margin: 0 auto 22rpx;
  max-width: 480rpx;
}

.room-code-label {
  color: #59647a;
  font-size: 24rpx;
  line-height: 1.2;
  margin-bottom: 8rpx;
}

.room-code {
  display: inline-block;
  padding: 16rpx 24rpx;
  margin-bottom: 8rpx;
  border-radius: 18rpx;
  border: 2rpx dashed rgba(228, 91, 88, 0.42);
  background: #fff3d7;
  color: #e45b58;
  font-size: 68rpx;
  font-weight: 700;
  line-height: 1;
  letter-spacing: 0;
}

.room-code-hint {
  color: #59647a;
  font-size: 22rpx;
  line-height: 1.35;
  margin-bottom: 28rpx;
}

.players-list {
  margin-bottom: 24rpx;
}

.player-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 12rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(240, 166, 65, 0.22);
  background: rgba(255, 255, 255, 0.7);
}

.player-item.empty {
  border-style: dashed;
  opacity: 0.72;
}

.player-avatar {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #315fb5 0%, #f0a641 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}

.player-name {
  flex: 1;
  color: #18213d;
  font-size: 28rpx;
  line-height: 1.25;
  text-align: left;
  min-width: 0;
}

.player-name.empty-text {
  color: rgba(89, 100, 122, 0.62);
}

.player-role {
  padding: 5rpx 14rpx;
  border-radius: 999rpx;
  color: #59647a;
  background: rgba(49, 95, 181, 0.1);
  font-size: 22rpx;
  line-height: 1.2;
}

.player-role.creator {
  color: #9a621e;
  background: #fff3d7;
}

.player-ready {
  color: #23856d;
  font-size: 22rpx;
  line-height: 1.2;
  flex-shrink: 0;
}

.btn-start,
.btn-share-room {
  width: 100%;
  min-height: 82rpx;
  padding: 0;
  border-radius: 999rpx;
  font-size: 30rpx;
  line-height: 82rpx;
  border: none;
}

.btn-start {
  background: linear-gradient(135deg, #e45b58 0%, #f0a641 100%);
  color: #ffffff;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.btn-start::after,
.btn-share-room::after {
  border: none;
}

.btn-start[disabled] {
  background: rgba(255, 255, 255, 0.58);
  color: rgba(89, 100, 122, 0.58);
  border: 1rpx solid rgba(240, 166, 65, 0.18);
}

.waiting-hint {
  padding: 20rpx 0;
  color: #59647a;
  font-size: 26rpx;
  line-height: 1.4;
}

.btn-share-room {
  background: rgba(255, 255, 255, 0.72);
  color: #315fb5;
  border: 1rpx solid rgba(49, 95, 181, 0.18);
}
