.page {
  min-height: 100vh;
  padding: calc(106rpx + env(safe-area-inset-top)) 24rpx 136rpx;
  box-sizing: border-box;
  background:
    linear-gradient(180deg, #f1f5ff 0%, #e4ebfb 55%, #edf3ff 100%),
    repeating-linear-gradient(90deg, rgba(55, 86, 152, 0.032) 0, rgba(55, 86, 152, 0.032) 1rpx, transparent 1rpx, transparent 26rpx);
  color: #18213d;
}

.section-title {
  max-width: 650rpx;
  margin: 0 auto 24rpx;
  color: #18213d;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.2;
  text-align: center;
}

.rank-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  width: 100%;
  max-width: 650rpx;
  margin: 0 auto;
}

.rank-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(55, 86, 152, 0.16);
  background: rgba(255, 255, 255, 0.86);
  box-shadow: 0 8rpx 22rpx rgba(28, 57, 112, 0.06);
  box-sizing: border-box;
}

.rank-badge {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #edf3ff;
  border: 1rpx solid rgba(89, 100, 122, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.rank-badge.gold {
  background: #fff3d7;
  border-color: rgba(240, 166, 65, 0.28);
}

.rank-badge.silver {
  background: #eef3f5;
  border-color: rgba(49, 95, 181, 0.22);
}

.rank-badge.bronze {
  background: #fff0ef;
  border-color: rgba(228, 91, 88, 0.24);
}

.rank-medal,
.rank-badge .rank-num {
  color: #59647a;
  font-size: 24rpx;
  font-weight: 700;
}

.rank-badge.gold .rank-medal {
  color: #9a621e;
}

.rank-badge.silver .rank-medal {
  color: #315fb5;
}

.rank-badge.bronze .rank-medal {
  color: #e45b58;
}

.rank-badge.gold .rank-num,
.rank-badge.silver .rank-num,
.rank-badge.bronze .rank-num {
  display: none;
}

.rank-center {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 5rpx;
  min-width: 0;
}

.rank-player {
  color: #18213d;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.25;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rank-answer {
  color: #59647a;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.2;
  letter-spacing: 0;
}

.rank-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  flex-shrink: 0;
}

.rank-count {
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.2;
}

.rank-count.won {
  color: #315fb5;
}

.rank-count.lost {
  color: #e45b58;
}

.box-row {
  display: flex;
  gap: 5rpx;
}

.guess-box {
  width: 26rpx;
  height: 26rpx;
  border-radius: 5rpx;
  border: 2rpx solid rgba(89, 100, 122, 0.26);
  box-sizing: border-box;
}

.guess-box.correct {
  background-color: #23856d;
  border-color: #1c6b58;
}

.guess-box.pinyin {
  background-color: #315fb5;
  border-color: #274c96;
}

.guess-box.present {
  background-color: #d88c2e;
  border-color: #9a621e;
}

.guess-box.partial {
  background-color: #7a67b7;
  border-color: #6d5da3;
}

.guess-box.absent {
  background-color: #8b93a1;
  border-color: #737b8d;
}

.guess-box.empty {
  background-color: rgba(255, 255, 255, 0.48);
  border-color: rgba(89, 100, 122, 0.22);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  max-width: 650rpx;
  margin: 150rpx auto 0;
  padding: 46rpx 28rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(55, 86, 152, 0.16);
  background: rgba(255, 255, 255, 0.72);
  box-sizing: border-box;
}

.empty-icon {
  width: 74rpx;
  height: 74rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(49, 95, 181, 0.28);
  color: #315fb5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
}

.empty-text {
  color: #18213d;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.3;
}

.empty-sub {
  color: #59647a;
  font-size: 24rpx;
  line-height: 1.4;
  margin-top: 8rpx;
}
