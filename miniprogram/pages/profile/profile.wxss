/* ========== 滚动容器 ========== */
.page-scroll {
  height: 100vh;
  overflow-y: auto;
}

.page {
  padding: calc(170rpx + env(safe-area-inset-top)) 20rpx 20rpx;
  box-sizing: border-box;
}

/* ========== 玩家信息卡片 ========== */
.player-card {
  background: linear-gradient(135deg, #1E3A5F 0%, #1E293B 50%, #1A1A2E 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
}
.player-card::before {
  content: '';
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 140rpx;
  height: 140rpx;
  background: rgba(59, 130, 246, 0.1);
  border-radius: 50%;
}
.player-avatar-wrap {
  display: flex;
  align-items: center;
  gap: 20rpx;
  position: relative;
  z-index: 1;
}
.player-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #334155;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #475569;
  flex-shrink: 0;
  position: relative;
  overflow: hidden;
}
.player-avatar.male {
  border-color: #3B82F6;
  background: #1E3A5F;
}
.player-avatar.female {
  border-color: #EC4899;
  background: #4A1D3A;
}
.avatar-emoji {
  font-size: 48rpx;
}
.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}
.avatar-camera-tip {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 34rpx;
  height: 34rpx;
  background: rgba(0,0,0,0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  opacity: 0;
  transition: opacity 0.2s;
}
.player-avatar:active .avatar-camera-tip {
  opacity: 1;
}
.player-basic {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.player-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #F1F5F9;
}
.player-city {
  font-size: 24rpx;
  color: #64748B;
}
.player-edit-btn {
  padding: 10rpx 24rpx;
  background: rgba(59, 130, 246, 0.2);
  border: 1rpx solid rgba(59, 130, 246, 0.4);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #60A5FA;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}
.player-edit-btn:active {
  background: rgba(59, 130, 246, 0.4);
}
.player-signature {
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: rgba(255,255,255,0.05);
  border-radius: 10rpx;
  font-size: 24rpx;
  color: #94A3B8;
  position: relative;
  z-index: 1;
  line-height: 1.6;
}
.player-signature.empty {
  color: #475569;
  font-style: italic;
}

/* ========== 胜率卡片 ========== */
.winrate-card {
  display: flex;
  background: #1E293B;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 24rpx;
}
.wr-item {
  flex: 1;
  text-align: center;
}
.wr-num {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #F1F5F9;
}
.wr-num.accent {
  color: #3B82F6;
}
.wr-label {
  display: block;
  font-size: 22rpx;
  color: #64748B;
  margin-top: 4rpx;
}
.wr-divider {
  width: 1rpx;
  background: #334155;
}

.section {
  background: #1E293B;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.section:last-of-type {
  margin-bottom: 0;
}
.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #F1F5F9;
  margin-bottom: 20rpx;
}

/* 猜次分布 */
.dist-chart {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.dist-bar-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.dist-label {
  width: 50rpx;
  font-size: 24rpx;
  color: #64748B;
  text-align: right;
}
.dist-bar-wrap {
  flex: 1;
  height: 36rpx;
  background: #0F172A;
  border-radius: 8rpx;
  overflow: hidden;
}
.dist-bar {
  height: 100%;
  background: linear-gradient(90deg, #3B82F6, #60A5FA);
  border-radius: 8rpx;
  min-width: 40rpx;
  display: flex;
  align-items: center;
  padding-left: 12rpx;
  transition: width 0.5s ease;
}
.dist-bar-text {
  font-size: 22rpx;
  color: #F1F5F9;
  font-weight: bold;
}

.dist-empty {
  text-align: center;
  font-size: 26rpx;
  color: #64748B;
  padding: 20rpx 0;
}
.dist-empty-btn {
  display: inline-block;
  margin-top: 20rpx;
  padding: 16rpx 40rpx;
  background: linear-gradient(135deg, #3B82F6, #2563EB);
  color: #F1F5F9;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
}
.dist-empty-btn:active { opacity: 0.85; }
.dist-summary {
  margin-top: 16rpx;
  text-align: center;
  font-size: 24rpx;
  color: #64748B;
}

/* 近期谜底 */
.recent-list {
  display: flex;
  flex-direction: column;
}
.recent-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #334155;
}
.recent-item:last-child { border-bottom: none; }
.recent-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.recent-date {
  font-size: 22rpx;
  color: #64748B;
}
.recent-answer {
  font-size: 32rpx;
  color: #F1F5F9;
  font-weight: bold;
  letter-spacing: 8rpx;
}
.recent-result {
  font-size: 28rpx;
  font-weight: bold;
}
.recent-result.won { color: #22C55E; }
.recent-result.lost { color: #EF4444; }

/* ========== 编辑弹窗 ========== */
.editor-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}
.editor-overlay.show {
  opacity: 1;
  pointer-events: auto;
}
.editor-card {
  background: #1E293B;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  width: 85%;
  max-width: 560rpx;
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.3);
  animation: slideUp 0.3s ease;
}
@keyframes slideUp {
  from { transform: translateY(60rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}
.editor-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #F1F5F9;
  text-align: center;
  margin-bottom: 30rpx;
}

.editor-field {
  margin-bottom: 24rpx;
}
.editor-label {
  display: block;
  font-size: 26rpx;
  color: #94A3B8;
  margin-bottom: 10rpx;
}
.editor-input {
  width: 100%;
  height: 80rpx;
  background: #0F172A;
  border: 2rpx solid #334155;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #F1F5F9;
  box-sizing: border-box;
}
.editor-textarea {
  width: 100%;
  min-height: 100rpx;
  background: #0F172A;
  border: 2rpx solid #334155;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #F1F5F9;
  box-sizing: border-box;
}

/* 头像选择器 */
.avatar-picker {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #0F172A;
  border: 2rpx dashed #475569;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  margin: 0 auto;
}
.avatar-pick-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}
.avatar-pick-placeholder {
  font-size: 56rpx;
}
.avatar-pick-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 40rpx;
  background: rgba(0,0,0,0.65);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #fff;
  border-radius: 0 0 60rpx 60rpx;
}

/* 性别选择 */
.gender-group {
  display: flex;
  gap: 12rpx;
}
.gender-option {
  flex: 1;
  padding: 16rpx 0;
  text-align: center;
  background: #0F172A;
  border: 2rpx solid #334155;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #94A3B8;
  transition: all 0.2s;
}
.gender-option.selected {
  border-color: #3B82F6;
  background: rgba(59, 130, 246, 0.15);
  color: #60A5FA;
}

.editor-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 30rpx;
}
.btn-cancel, .btn-save {
  flex: 1;
  padding: 20rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  text-align: center;
  border: none;
}
.btn-cancel {
  background: #334155;
  color: #94A3B8;
}
.btn-save {
  background: #3B82F6;
  color: #F1F5F9;
}
.btn-cancel:active, .btn-save:active { opacity: 0.8; }

/* ========== 设置 ========== */
.settings-section {
  margin-top: 8rpx;
}
.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #334155;
}
.setting-item:last-child { border-bottom: none; }
.setting-text {
  font-size: 26rpx;
  color: #F1F5F9;
}
.setting-arrow {
  font-size: 32rpx;
  color: #64748B;
}
.setting-version {
  font-size: 22rpx;
  color: #475569;
}

/* ========== 底部占位 ========== */
.bottom-spacer {
  height: 200rpx;
}
