.page-scroll {
  height: 100vh;
  overflow-y: auto;
  background:
    radial-gradient(circle at 14% 7%, rgba(255, 218, 142, 0.5) 0, rgba(255, 218, 142, 0) 190rpx),
    radial-gradient(circle at 88% 12%, rgba(108, 167, 225, 0.4) 0, rgba(108, 167, 225, 0) 210rpx),
    linear-gradient(180deg, #eaf4ff 0%, #f8efe0 54%, #eaf2ff 100%);
}

.page {
  padding: calc(72rpx + env(safe-area-inset-top)) 24rpx 20rpx;
  box-sizing: border-box;
  color: #18213d;
}

.profile-hero,
.player-card,
.winrate-card,
.profile-action-card,
.section {
  width: 100%;
  max-width: 650rpx;
  margin-left: auto;
  margin-right: auto;
  box-sizing: border-box;
}

.profile-hero {
  position: relative;
  overflow: hidden;
  min-height: 126rpx;
  margin-bottom: 18rpx;
  padding: 24rpx 126rpx 24rpx 26rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, rgba(49, 95, 181, 0.96) 0%, rgba(92, 125, 205, 0.94) 100%);
  box-shadow: 0 18rpx 38rpx rgba(28, 57, 112, 0.2);
  box-sizing: border-box;
}

.profile-hero::after {
  content: '';
  position: absolute;
  right: -24rpx;
  bottom: -44rpx;
  width: 166rpx;
  height: 166rpx;
  border-radius: 50%;
  border: 22rpx solid rgba(255, 255, 255, 0.16);
}

.profile-hero-copy {
  position: relative;
  z-index: 1;
}

.profile-kicker,
.profile-title,
.profile-subtitle {
  display: block;
  line-height: 1.2;
}

.profile-kicker {
  color: rgba(255, 255, 255, 0.82);
  font-size: 22rpx;
  font-weight: 800;
}

.profile-title {
  margin-top: 6rpx;
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 900;
}

.profile-subtitle {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.84);
  font-size: 23rpx;
}

.profile-seal {
  position: absolute;
  right: 26rpx;
  top: 50%;
  z-index: 2;
  width: 76rpx;
  height: 76rpx;
  border-radius: 18rpx;
  background: #e45b58;
  color: #fff9ee;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 900;
  transform: translateY(-50%) rotate(5deg);
  box-shadow: 0 10rpx 22rpx rgba(25, 45, 85, 0.18);
}

.player-card {
  position: relative;
  overflow: hidden;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(240, 166, 65, 0.28);
  background: linear-gradient(180deg, rgba(255, 252, 242, 0.98) 0%, rgba(255, 238, 202, 0.96) 100%);
  box-shadow: 0 22rpx 46rpx rgba(151, 97, 28, 0.15);
}

.player-card::before {
  content: '';
  position: absolute;
  right: -34rpx;
  top: -38rpx;
  width: 172rpx;
  height: 172rpx;
  border-radius: 50%;
  background: rgba(228, 91, 88, 0.08);
}

.player-card::after {
  content: '印';
  position: absolute;
  right: 34rpx;
  top: 28rpx;
  width: 74rpx;
  height: 74rpx;
  border-radius: 18rpx;
  background: #e45b58;
  color: #fff9ee;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 900;
  transform: rotate(5deg);
  box-shadow: 0 10rpx 22rpx rgba(228, 91, 88, 0.22);
}

.player-avatar-wrap {
  display: flex;
  align-items: center;
  gap: 18rpx;
  position: relative;
  z-index: 1;
}

.player-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #315fb5 0%, #f0a641 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #ffffff;
  flex-shrink: 0;
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
  box-shadow: 0 10rpx 22rpx rgba(28, 57, 112, 0.14);
}

.player-avatar.male {
  border-color: #ffffff;
  background: linear-gradient(135deg, #315fb5 0%, #5f73c7 100%);
}

.player-avatar.female {
  border-color: #ffffff;
  background: linear-gradient(135deg, #7a67b7 0%, #f0a641 100%);
}

.avatar-emoji {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-camera-tip {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 34rpx;
  height: 34rpx;
  background: #e45b58;
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16rpx;
  line-height: 1;
}

.player-basic {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.player-name {
  color: #18213d;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.player-city {
  color: #9a621e;
  font-size: 24rpx;
  line-height: 1.3;
}

.player-edit-btn {
  min-width: 88rpx;
  padding: 11rpx 22rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  color: #ffffff;
  background: linear-gradient(135deg, #e45b58 0%, #f0a641 100%);
  font-size: 24rpx;
  line-height: 1.2;
  text-align: center;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
  box-sizing: border-box;
}

.player-edit-btn:active {
  opacity: 0.86;
}

.player-signature {
  position: relative;
  z-index: 1;
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.58);
  border: 1rpx solid rgba(154, 98, 30, 0.18);
  color: #59647a;
  font-size: 24rpx;
  line-height: 1.55;
}

.player-signature.empty {
  color: rgba(89, 100, 122, 0.62);
}

.winrate-card {
  display: flex;
  padding: 28rpx 18rpx;
  margin-bottom: 20rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  background: rgba(255, 255, 255, 0.72);
  box-shadow: 0 12rpx 28rpx rgba(28, 57, 112, 0.08);
  backdrop-filter: blur(10rpx);
}

.profile-action-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  background: rgba(255, 255, 255, 0.78);
  box-shadow: 0 12rpx 28rpx rgba(28, 57, 112, 0.08);
  backdrop-filter: blur(10rpx);
}

.profile-action-title,
.profile-action-sub {
  display: block;
  line-height: 1.25;
}

.profile-action-title {
  color: #18213d;
  font-size: 28rpx;
  font-weight: 900;
}

.profile-action-sub {
  margin-top: 8rpx;
  color: #59647a;
  font-size: 23rpx;
}

.profile-action-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.profile-action-btn {
  min-height: 74rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.profile-action-btn.primary {
  color: #ffffff;
  background: linear-gradient(135deg, #e45b58 0%, #f0a641 100%);
  box-shadow: 0 12rpx 24rpx rgba(228, 91, 88, 0.18);
}

.profile-action-btn.secondary {
  color: #315fb5;
  background: rgba(255, 255, 255, 0.74);
  border: 1rpx solid rgba(49, 95, 181, 0.18);
}

.profile-action-btn:active {
  opacity: 0.86;
  transform: translateY(2rpx);
}

.wr-item {
  flex: 1;
  text-align: center;
}

.wr-num {
  display: block;
  color: #18213d;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.15;
}

.wr-num.accent {
  color: #e45b58;
}

.wr-label {
  display: block;
  color: #59647a;
  font-size: 22rpx;
  line-height: 1.3;
  margin-top: 6rpx;
}

.wr-divider {
  width: 1rpx;
  background: rgba(55, 86, 152, 0.18);
}

.section {
  padding: 24rpx;
  margin-bottom: 20rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  background: rgba(255, 255, 255, 0.78);
  box-shadow: 0 12rpx 28rpx rgba(28, 57, 112, 0.08);
  backdrop-filter: blur(10rpx);
}

.section:last-of-type {
  margin-bottom: 0;
}

.section-title {
  color: #18213d;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.25;
  margin-bottom: 20rpx;
}

.dist-chart {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.dist-bar-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.dist-label {
  width: 54rpx;
  color: #59647a;
  font-size: 24rpx;
  line-height: 1.2;
  text-align: right;
}

.dist-bar-wrap {
  flex: 1;
  height: 36rpx;
  border-radius: 999rpx;
  background: rgba(49, 95, 181, 0.1);
  overflow: hidden;
}

.dist-bar {
  height: 100%;
  min-width: 40rpx;
  padding-left: 12rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #e45b58 0%, #f0a641 100%);
  display: flex;
  align-items: center;
  box-sizing: border-box;
  transition: width 0.35s ease;
}

.dist-bar-text {
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
}

.dist-summary {
  margin-top: 16rpx;
  color: #59647a;
  font-size: 24rpx;
  line-height: 1.4;
  text-align: center;
}

.dist-empty {
  padding: 22rpx 0;
  color: #59647a;
  font-size: 26rpx;
  line-height: 1.45;
  text-align: center;
}

.dist-empty-btn {
  display: inline-block;
  min-height: 76rpx;
  margin-top: 18rpx;
  padding: 0 36rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #e45b58 0%, #f0a641 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 76rpx;
}

.dist-empty-btn:active {
  opacity: 0.86;
}

.recent-list {
  display: flex;
  flex-direction: column;
}

.recent-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(55, 86, 152, 0.14);
}

.recent-item:last-child {
  border-bottom: none;
}

.recent-left {
  display: flex;
  flex-direction: column;
  gap: 5rpx;
  min-width: 0;
}

.recent-date {
  color: #59647a;
  font-size: 22rpx;
  line-height: 1.2;
}

.recent-answer {
  color: #18213d;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.25;
  letter-spacing: 0;
}

.recent-result {
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.2;
}

.recent-result.won {
  color: #23856d;
}

.recent-result.lost {
  color: #e45b58;
}

.settings-section {
  margin-top: 8rpx;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 78rpx;
  border-bottom: 1rpx solid rgba(55, 86, 152, 0.14);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-text {
  color: #18213d;
  font-size: 26rpx;
  line-height: 1.3;
}

.setting-arrow {
  color: #e45b58;
  font-size: 32rpx;
  line-height: 1;
}

.setting-version {
  color: rgba(89, 100, 122, 0.68);
  font-size: 22rpx;
}

.bottom-spacer {
  height: 190rpx;
}

.editor-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(24, 33, 61, 0.58);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s ease;
  padding: 40rpx;
  box-sizing: border-box;
}

.editor-overlay.show {
  opacity: 1;
  pointer-events: auto;
}

.editor-card {
  width: 100%;
  max-width: 560rpx;
  max-height: 80vh;
  overflow-y: auto;
  padding: 38rpx 30rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(240, 166, 65, 0.28);
  background: linear-gradient(180deg, #fffdf7 0%, #fff0d6 100%);
  box-shadow: 0 24rpx 66rpx rgba(28, 57, 112, 0.24);
  box-sizing: border-box;
  animation: slideUp 0.28s ease;
}

@keyframes slideUp {
  from { transform: translateY(60rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.editor-title {
  color: #18213d;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.25;
  text-align: center;
  margin-bottom: 8rpx;
}

.editor-subtitle {
  color: #9a621e;
  font-size: 23rpx;
  line-height: 1.4;
  text-align: center;
  margin-bottom: 28rpx;
}

.editor-field {
  margin-bottom: 24rpx;
}

.editor-label {
  display: block;
  color: #59647a;
  font-size: 25rpx;
  line-height: 1.25;
  margin-bottom: 10rpx;
}

.editor-input,
.editor-textarea {
  width: 100%;
  border: 1rpx solid rgba(240, 166, 65, 0.28);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.86);
  color: #18213d;
  font-size: 28rpx;
  box-sizing: border-box;
}

.editor-input {
  height: 80rpx;
  padding: 0 20rpx;
}

.editor-textarea {
  min-height: 100rpx;
  padding: 16rpx 20rpx;
}

.avatar-picker {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #315fb5 0%, #f0a641 100%);
  border: 4rpx solid #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  margin: 0 auto;
  box-sizing: border-box;
}

.avatar-pick-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-pick-placeholder {
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 700;
}

.avatar-pick-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 40rpx;
  background: rgba(228, 91, 88, 0.88);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  border-radius: 0 0 60rpx 60rpx;
}

.gender-group {
  display: flex;
  gap: 12rpx;
}

.gender-option {
  flex: 1;
  min-height: 76rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(240, 166, 65, 0.24);
  background: rgba(255, 255, 255, 0.66);
  color: #59647a;
  font-size: 24rpx;
  line-height: 76rpx;
  text-align: center;
  box-sizing: border-box;
  transition: background 0.2s, border-color 0.2s;
}

.gender-option.selected {
  border-color: rgba(228, 91, 88, 0.42);
  background: #fff3d7;
  color: #e45b58;
  font-weight: 700;
}

.editor-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 30rpx;
}

.btn-cancel,
.btn-save {
  flex: 1;
  min-height: 82rpx;
  padding: 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  line-height: 82rpx;
  text-align: center;
  border: none;
}

.btn-cancel::after,
.btn-save::after {
  border: none;
}

.btn-cancel {
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid rgba(240, 166, 65, 0.24);
  color: #59647a;
}

.btn-save {
  background: linear-gradient(135deg, #e45b58 0%, #f0a641 100%);
  color: #ffffff;
  font-weight: 700;
}

.btn-cancel:active,
.btn-save:active {
  opacity: 0.86;
}
