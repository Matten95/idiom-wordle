.page-scroll {
  height: 100vh;
  overflow-y: auto;
  background:
    linear-gradient(180deg, #f1f5ff 0%, #e4ebfb 55%, #edf3ff 100%),
    repeating-linear-gradient(90deg, rgba(55, 86, 152, 0.032) 0, rgba(55, 86, 152, 0.032) 1rpx, transparent 1rpx, transparent 26rpx);
}

.page {
  padding: calc(100rpx + env(safe-area-inset-top)) 24rpx 20rpx;
  box-sizing: border-box;
  color: #18213d;
}

.player-card,
.winrate-card,
.section {
  width: 100%;
  max-width: 650rpx;
  margin-left: auto;
  margin-right: auto;
  box-sizing: border-box;
}

.player-card {
  position: relative;
  overflow: hidden;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(55, 86, 152, 0.16);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(237, 243, 255, 0.96) 100%);
  box-shadow: 0 14rpx 40rpx rgba(28, 57, 112, 0.09);
}

.player-card::before {
  content: '';
  position: absolute;
  top: 18rpx;
  left: 22rpx;
  right: 22rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(49, 95, 181, 0.28), transparent);
}

.player-avatar-wrap {
  display: flex;
  align-items: center;
  gap: 18rpx;
  position: relative;
  z-index: 1;
}

.player-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #edf3ff;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid rgba(89, 100, 122, 0.26);
  flex-shrink: 0;
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
}

.player-avatar.male {
  border-color: rgba(49, 95, 181, 0.42);
  background: #edf3ff;
}

.player-avatar.female {
  border-color: rgba(122, 103, 183, 0.42);
  background: #f1ecff;
}

.avatar-emoji {
  color: #315fb5;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-camera-tip {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 34rpx;
  height: 34rpx;
  background: rgba(28, 57, 112, 0.72);
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16rpx;
  line-height: 1;
}

.player-basic {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.player-name {
  color: #18213d;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.player-city {
  color: #59647a;
  font-size: 24rpx;
  line-height: 1.3;
}

.player-edit-btn {
  min-width: 88rpx;
  padding: 11rpx 22rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(49, 95, 181, 0.24);
  color: #315fb5;
  background: #edf3ff;
  font-size: 24rpx;
  line-height: 1.2;
  text-align: center;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
  box-sizing: border-box;
}

.player-edit-btn:active {
  opacity: 0.86;
}

.player-signature {
  position: relative;
  z-index: 1;
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  border-radius: 10rpx;
  background: rgba(237, 243, 255, 0.86);
  border: 1rpx solid rgba(49, 95, 181, 0.12);
  color: #59647a;
  font-size: 24rpx;
  line-height: 1.55;
}

.player-signature.empty {
  color: rgba(89, 100, 122, 0.62);
}

.winrate-card {
  display: flex;
  padding: 28rpx 18rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(55, 86, 152, 0.16);
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 8rpx 24rpx rgba(28, 57, 112, 0.06);
}

.wr-item {
  flex: 1;
  text-align: center;
}

.wr-num {
  display: block;
  color: #18213d;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.15;
}

.wr-num.accent {
  color: #315fb5;
}

.wr-label {
  display: block;
  color: #59647a;
  font-size: 22rpx;
  line-height: 1.3;
  margin-top: 6rpx;
}

.wr-divider {
  width: 1rpx;
  background: rgba(55, 86, 152, 0.18);
}

.section {
  padding: 24rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(55, 86, 152, 0.16);
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 8rpx 24rpx rgba(28, 57, 112, 0.06);
}

.section:last-of-type {
  margin-bottom: 0;
}

.section-title {
  color: #18213d;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.25;
  margin-bottom: 20rpx;
}

.dist-chart {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.dist-bar-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.dist-label {
  width: 54rpx;
  color: #59647a;
  font-size: 24rpx;
  line-height: 1.2;
  text-align: right;
}

.dist-bar-wrap {
  flex: 1;
  height: 36rpx;
  border-radius: 8rpx;
  background: #edf3ff;
  overflow: hidden;
}

.dist-bar {
  height: 100%;
  min-width: 40rpx;
  padding-left: 12rpx;
  border-radius: 8rpx;
  background: linear-gradient(135deg, #315fb5 0%, #5f73c7 100%);
  display: flex;
  align-items: center;
  box-sizing: border-box;
  transition: width 0.35s ease;
}

.dist-bar-text {
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
}

.dist-summary {
  margin-top: 16rpx;
  color: #59647a;
  font-size: 24rpx;
  line-height: 1.4;
  text-align: center;
}

.dist-empty {
  padding: 22rpx 0;
  color: #59647a;
  font-size: 26rpx;
  line-height: 1.45;
  text-align: center;
}

.dist-empty-btn {
  display: inline-block;
  min-height: 76rpx;
  margin-top: 18rpx;
  padding: 0 36rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #315fb5 0%, #5f73c7 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 76rpx;
}

.dist-empty-btn:active {
  opacity: 0.86;
}

.recent-list {
  display: flex;
  flex-direction: column;
}

.recent-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(55, 86, 152, 0.14);
}

.recent-item:last-child {
  border-bottom: none;
}

.recent-left {
  display: flex;
  flex-direction: column;
  gap: 5rpx;
  min-width: 0;
}

.recent-date {
  color: #59647a;
  font-size: 22rpx;
  line-height: 1.2;
}

.recent-answer {
  color: #18213d;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.25;
  letter-spacing: 0;
}

.recent-result {
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.2;
}

.recent-result.won {
  color: #315fb5;
}

.recent-result.lost {
  color: #e45b58;
}

.settings-section {
  margin-top: 8rpx;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 78rpx;
  border-bottom: 1rpx solid rgba(55, 86, 152, 0.14);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-text {
  color: #18213d;
  font-size: 26rpx;
  line-height: 1.3;
}

.setting-arrow {
  color: #59647a;
  font-size: 32rpx;
  line-height: 1;
}

.setting-version {
  color: rgba(89, 100, 122, 0.68);
  font-size: 22rpx;
}

.bottom-spacer {
  height: 190rpx;
}

.editor-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(28, 57, 112, 0.58);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s ease;
  padding: 40rpx;
  box-sizing: border-box;
}

.editor-overlay.show {
  opacity: 1;
  pointer-events: auto;
}

.editor-card {
  width: 100%;
  max-width: 560rpx;
  max-height: 80vh;
  overflow-y: auto;
  padding: 38rpx 30rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(55, 86, 152, 0.18);
  background: linear-gradient(180deg, #ffffff 0%, #edf3ff 100%);
  box-shadow: 0 22rpx 60rpx rgba(28, 57, 112, 0.22);
  box-sizing: border-box;
  animation: slideUp 0.28s ease;
}

@keyframes slideUp {
  from { transform: translateY(60rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.editor-title {
  color: #18213d;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.25;
  text-align: center;
  margin-bottom: 28rpx;
}

.editor-field {
  margin-bottom: 24rpx;
}

.editor-label {
  display: block;
  color: #59647a;
  font-size: 25rpx;
  line-height: 1.25;
  margin-bottom: 10rpx;
}

.editor-input,
.editor-textarea {
  width: 100%;
  border: 1rpx solid rgba(55, 86, 152, 0.22);
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.82);
  color: #18213d;
  font-size: 28rpx;
  box-sizing: border-box;
}

.editor-input {
  height: 80rpx;
  padding: 0 20rpx;
}

.editor-textarea {
  min-height: 100rpx;
  padding: 16rpx 20rpx;
}

.avatar-picker {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #edf3ff;
  border: 2rpx dashed rgba(89, 100, 122, 0.36);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  margin: 0 auto;
  box-sizing: border-box;
}

.avatar-pick-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-pick-placeholder {
  color: #315fb5;
  font-size: 38rpx;
  font-weight: 700;
}

.avatar-pick-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 40rpx;
  background: rgba(28, 57, 112, 0.72);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  border-radius: 0 0 60rpx 60rpx;
}

.gender-group {
  display: flex;
  gap: 12rpx;
}

.gender-option {
  flex: 1;
  min-height: 76rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(55, 86, 152, 0.22);
  background: rgba(255, 255, 255, 0.62);
  color: #59647a;
  font-size: 24rpx;
  line-height: 76rpx;
  text-align: center;
  box-sizing: border-box;
  transition: background 0.2s, border-color 0.2s;
}

.gender-option.selected {
  border-color: rgba(49, 95, 181, 0.46);
  background: #edf3ff;
  color: #315fb5;
  font-weight: 700;
}

.editor-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 30rpx;
}

.btn-cancel,
.btn-save {
  flex: 1;
  min-height: 82rpx;
  padding: 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 82rpx;
  text-align: center;
  border: none;
}

.btn-cancel::after,
.btn-save::after {
  border: none;
}

.btn-cancel {
  background: rgba(255, 255, 255, 0.58);
  border: 1rpx solid rgba(55, 86, 152, 0.24);
  color: #59647a;
}

.btn-save {
  background: linear-gradient(135deg, #315fb5 0%, #5f73c7 100%);
  color: #ffffff;
  font-weight: 700;
}

.btn-cancel:active,
.btn-save:active {
  opacity: 0.86;
}
