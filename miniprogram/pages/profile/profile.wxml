<scroll-view class="page-scroll" scroll-y="true" enhanced="true" show-scrollbar="{{false}}">
<view class="page">

  <view class="profile-hero">
    <view class="profile-hero-copy">
      <text class="profile-kicker">我的印记册</text>
      <text class="profile-title">成语侠客档案</text>
      <text class="profile-subtitle">今日破题和连胜都会留在这里</text>
    </view>
    <view class="profile-seal"><text>册</text></view>
  </view>

  <!-- ========== 玩家信息卡片 ========== -->
  <view class="player-card">
    <view class="player-avatar-wrap">
      <view class="player-avatar {{player.gender === 'male' ? 'male' : player.gender === 'female' ? 'female' : ''}}" bindtap="onShowEditor">
        <image wx:if="{{player.avatar}}" class="avatar-img" src="{{player.avatar}}" mode="aspectFill" />
        <text wx:else class="avatar-emoji">{{player.gender === 'male' ? '男' : player.gender === 'female' ? '女' : '人'}}</text>
        <view class="avatar-camera-tip"><text>换</text></view>
      </view>
      <view class="player-basic">
        <text class="player-name">{{player.nickname || '未设置昵称'}}</text>
        <text class="player-city" wx:if="{{player.city}}">{{player.city}}</text>
      </view>
      <view class="player-edit-btn" bindtap="onShowEditor"><text>编辑</text></view>
    </view>
    <view class="player-signature" wx:if="{{player.signature}}">
      <text>「{{player.signature}}」</text>
    </view>
    <view class="player-signature empty" wx:else>
      <text>写一句个性签名吧...</text>
    </view>
  </view>

  <!-- 胜率卡片 -->
  <view class="winrate-card" wx:if="{{totalPlayed > 0}}">
    <view class="wr-item"><text class="wr-num">{{totalWon}}/{{totalPlayed}}</text><text class="wr-label">猜出/参与</text></view>
    <view class="wr-divider"></view>
    <view class="wr-item"><text class="wr-num accent">{{winRate}}%</text><text class="wr-label">胜率</text></view>
    <view class="wr-divider"></view>
    <view class="wr-item"><text class="wr-num">{{avgAttempts}}</text><text class="wr-label">平均猜次</text></view>
  </view>

  <view class="profile-action-card">
    <view class="profile-action-copy">
      <text class="profile-action-title">今日还想再破一题？</text>
      <text class="profile-action-sub">单人练手或拉好友开局，印记册继续加盖。</text>
    </view>
    <view class="profile-action-row">
      <view class="profile-action-btn primary" bindtap="onGoHome">今日挑战</view>
      <view class="profile-action-btn secondary" bindtap="onGoRoom">好友开局</view>
    </view>
  </view>

  <!-- 破题手感 -->
  <view class="section">
    <view class="section-title">破题手感</view>
    <view class="dist-chart">
      <view class="dist-bar-row" wx:for="{{distBars}}" wx:key="index">
        <text class="dist-label">{{index + 1}}次</text>
        <view class="dist-bar-wrap"><view class="dist-bar" style="width: {{item.pct}}%;"><text class="dist-bar-text" wx:if="{{item.count > 0}}">{{item.count}}</text></view></view>
      </view>
    </view>
    <view class="dist-summary" wx:if="{{totalPlayed > 0}}"><text>共 {{totalPlayed}} 场 · 胜率 {{winRate}}% · 平均 {{avgAttempts}} 次猜中</text></view>
    <view class="dist-empty" wx:if="{{totalPlayed === 0}}">
      <text>还没有游戏记录，去猜今天的成语吧！</text>
      <view class="dist-empty-btn" bindtap="onGoHome">开始今天的挑战</view>
    </view>
  </view>

  <!-- 近期记录 -->
  <view class="section" wx:if="{{recentGames.length > 0}}">
    <view class="section-title">最近破题</view>
    <view class="recent-list">
      <view class="recent-item" wx:for="{{recentGames}}" wx:key="date">
        <view class="recent-left"><text class="recent-date">{{item.dateDisplay}}</text><text class="recent-answer">{{item.answerText}}</text></view>
        <text class="recent-result {{item.won ? 'won' : 'lost'}}">{{item.won ? item.attempts + '/6' : '✗'}}</text>
      </view>
    </view>
  </view>

  <!-- 设置区域 -->
  <view class="section settings-section">
    <view class="section-title">小馆设置</view>
    <view class="setting-item" bindtap="onClearHistory" wx:if="{{totalPlayed > 0}}">
      <text class="setting-text">清空印记册</text><text class="setting-arrow">›</text>
    </view>
    <view class="setting-item">
      <text class="setting-text">关于成语挑战大厅</text><text class="setting-version">v1.0.0</text>
    </view>
  </view>

  <view class="bottom-spacer"></view>

</view>
</scroll-view>

<!-- 编辑弹窗 -->
<view class="editor-overlay {{showEditor ? 'show' : ''}}" bindtap="onHideEditor">
  <view class="editor-card" catchtap="onStopProp">
    <view class="editor-title">修订侠客印记</view>
    <view class="editor-subtitle">昵称、头像和签名都会盖进你的印记册。</view>

    <!-- 头像更换 -->
    <view class="editor-field">
      <text class="editor-label">头像印章</text>
      <view class="avatar-picker" bindtap="onChooseAvatar">
        <image wx:if="{{editAvatar}}" class="avatar-pick-img" src="{{editAvatar}}" mode="aspectFill" />
        <text wx:else class="avatar-pick-placeholder">人</text>
        <view class="avatar-pick-overlay"><text>换章</text></view>
      </view>
    </view>

    <!-- 昵称 — 非受控，无 maxlength 避免 IME 中断 -->
    <view class="editor-field">
      <text class="editor-label">江湖名号</text>
      <input class="editor-input"
        placeholder="给自己起个响亮的名号"
        placeholder-style="color:#59647a;"
        value="{{editNickname}}"
        hold-keyboard="{{true}}"
        bindinput="onNickInput"
        bindblur="onNickBlur"/>
    </view>

    <!-- 性别 -->
    <view class="editor-field">
      <text class="editor-label">档案标记</text>
      <view class="gender-group">
        <view class="gender-option {{editGender === 'male' ? 'selected' : ''}}" bindtap="onSelectGender" data-gender="male"><text>男</text></view>
        <view class="gender-option {{editGender === 'female' ? 'selected' : ''}}" bindtap="onSelectGender" data-gender="female"><text>女</text></view>
        <view class="gender-option {{editGender === '' ? 'selected' : ''}}" bindtap="onSelectGender" data-gender=""><text>保密</text></view>
      </view>
    </view>

    <!-- 城市 -->
    <view class="editor-field">
      <text class="editor-label">常驻小馆</text>
      <input class="editor-input"
        placeholder="留下你的城市"
        placeholder-style="color:#59647a;"
        value="{{editCity}}"
        hold-keyboard="{{true}}"
        bindinput="onCityInput"
        bindblur="onCityBlur"/>
    </view>

    <!-- 个性签名 -->
    <view class="editor-field">
      <text class="editor-label">印记题词</text>
      <textarea class="editor-textarea"
        placeholder="写一句破题宣言..."
        placeholder-style="color:#59647a;"
        value="{{editSignature}}"
        auto-height
        hold-keyboard="{{true}}"
        bindinput="onSigInput"
        bindblur="onSigBlur"/>
    </view>

    <view class="editor-actions">
      <button class="btn-cancel" bindtap="onHideEditor">先不改</button>
      <button class="btn-save" bindtap="onSavePlayer">盖上印记</button>
    </view>
  </view>
</view>

<!-- 底部导航 -->
<view class="tab-bar">
  <view class="tab-item" bindtap="onGoHome"><text class="tab-icon">首</text><text class="tab-text">首页</text></view>
  <view class="tab-item" bindtap="onGoRank"><text class="tab-icon">印</text><text class="tab-text">印记</text></view>
  <view class="tab-item active"><text class="tab-icon">我</text><text class="tab-text">我的</text></view>
</view>
