<view class="page">

  <view class="hero">
    <view class="hero-icon">🏮</view>
    <view class="hero-title">Wordle 成语版</view>
    <view class="hero-subtitle">每天一个成语，与好友比试身手</view>
  </view>

  <!-- 今日谜题卡片 -->
  <view class="today-card">
    <view class="today-meta">
      <text class="today-date">📅 {{dateDisplay}}</text>
      <text class="today-label">每日谜题</text>
    </view>

    <!-- 部首提示 -->
    <view class="hint-row">
      <view class="hint-cell" wx:for="{{hintRadicals}}" wx:key="index">
        <text wx:if="{{item !== '?'}}" class="hint-char hint-{{hintPositions[index] || 'center'}}">{{item}}</text>
        <text wx:else class="hint-q">?</text>
      </view>
    </view>
    <text class="hint-label">部首提示（共4个部首，显示其中2个）</text>
  </view>

  <!-- 状态提示 -->
  <view class="status-bar" wx:if="{{streakDays >= 3 || todayPlayed}}">
    <view class="status-item" wx:if="{{streakDays >= 3}}">
      <text class="status-icon">🔥</text>
      <text class="status-text">连击 {{streakDays}} 天</text>
    </view>
    <view class="status-item" wx:if="{{todayPlayed}}">
      <text class="status-icon">✅</text>
      <text class="status-text">今日已完成</text>
    </view>
  </view>

  <!-- 开始按钮 -->
  <view class="actions">
    <button class="btn-start" bindtap="onStartGame">
      <text class="btn-start-icon">🎯</text>
      <text class="btn-start-text">{{todayPlayed ? '查看今日战绩' : '开始今天的挑战'}}</text>
    </button>
    <button class="btn-practice" bindtap="onStartPractice">
      <text class="btn-start-icon">🎮</text>
      <text class="btn-start-text">自由练习</text>
    </button>
  </view>

  <!-- 玩法说明 -->
  <view class="rules-card">
    <view class="rules-title">📖 玩法说明</view>

    <view class="rule-step">
      <view class="rule-num">1</view>
      <view class="rule-content">
        <text class="rule-title">猜一个四字成语</text>
        <text class="rule-desc">你有 6 次机会，根据部首提示猜出今天的成语</text>
      </view>
    </view>

    <view class="rule-step">
      <view class="rule-num">2</view>
      <view class="rule-content">
        <text class="rule-title">提交后得到颜色反馈</text>
        <view class="color-legend">
          <view class="color-item"><view class="color-box correct">字</view><text>字对位对</text></view>
          <view class="color-item"><view class="color-box pinyin">字</view><text>同音不同字</text></view>
          <view class="color-item"><view class="color-box present">字</view><text>字对位不对</text></view>
          <view class="color-item"><view class="color-box partial">字</view><text>拼音部分对</text></view>
          <view class="color-item"><view class="color-box absent">字</view><text>都不对</text></view>
        </view>
      </view>
    </view>

    <view class="rule-step">
      <view class="rule-num">3</view>
      <view class="rule-content">
        <text class="rule-title">分享战绩给朋友</text>
        <text class="rule-desc">猜完后可以分享 emoji 战绩，和朋友比试比试</text>
      </view>
    </view>
  </view>

  <!-- 底部导航 -->
  <view class="tab-bar">
    <view class="tab-item active">
      <text class="tab-icon">🏠</text>
      <text class="tab-text">首页</text>
    </view>
    <view class="tab-item" bindtap="onLeaderboard">
      <text class="tab-icon">🏆</text>
      <text class="tab-text">排行</text>
    </view>
    <view class="tab-item" bindtap="onProfile">
      <text class="tab-icon">👤</text>
      <text class="tab-text">我的</text>
    </view>
  </view>

</view>
