<view class="page">
  <view class="home-shell">
    <view class="topline">
      <view class="title-block">
        <text class="brand-title">成语日课</text>
        <view class="date-row">
          <text class="today-date">{{dateDisplay}}</text>
          <text class="puzzle-number">{{puzzleNumberText}}</text>
        </view>
      </view>
      <view class="status-pill {{statusClass}}">{{statusText}}</view>
    </view>

    <view class="puzzle-paper">
      <view class="paper-head">
        <text class="paper-kicker">今日谜题笺</text>
        <text class="paper-seal">日课</text>
      </view>

      <view class="hint-row">
        <view class="hint-cell {{item.toneClass}}" wx:for="{{hintCells}}" wx:key="key">
          <text class="cell-index">{{item.indexLabel}}</text>
          <text wx:if="{{item.hasHint}}" class="hint-char {{item.positionClass}}">{{item.radical}}</text>
          <text wx:else class="hint-q">?</text>
        </view>
      </view>

      <view class="paper-meta">
        <text>{{revealedCountText}}</text>
        <text>拼音反馈</text>
        <text>{{streakText}}</text>
      </view>

      <button class="primary-cta" bindtap="onStartGame">{{primaryCtaText}}</button>
    </view>

    <view class="secondary-grid">
      <view class="secondary-action action-hint" bindtap="onIdiomMatch">
        <text class="action-name">提示猜词</text>
        <text class="action-desc">读线索猜成语</text>
      </view>
      <view class="secondary-action action-practice" bindtap="onStartPractice">
        <text class="action-name">自由练习</text>
        <text class="action-desc">常见题热身</text>
      </view>
      <view class="secondary-action action-two" bindtap="onTwoPlayer">
        <text class="action-name">双人对战</text>
        <text class="action-desc">一人出题一人猜</text>
      </view>
    </view>

    <view class="retention-strip">
      <view class="note-block">
        <text class="note-label">今日札记</text>
        <text class="note-text">{{dailyNote}}</text>
      </view>
      <view class="chip-row">
        <text class="status-chip" wx:for="{{statusChips}}" wx:key="key">{{item.text}}</text>
      </view>
    </view>

    <view class="quiet-links">
      <view class="quiet-link" bindtap="onLeaderboard">
        <text class="quiet-title">好友榜</text>
        <text class="quiet-desc">看看今日排名</text>
      </view>
      <view class="quiet-link" bindtap="onProfile">
        <text class="quiet-title">我的印记</text>
        <text class="quiet-desc">回看历史记录</text>
      </view>
    </view>
  </view>
</view>
