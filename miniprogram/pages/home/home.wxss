.page {
  min-height: 100vh;
  padding: calc(64rpx + env(safe-area-inset-top)) 28rpx 56rpx;
  box-sizing: border-box;
  color: #18213d;
  background:
    radial-gradient(circle at 14% 8%, rgba(255, 218, 142, 0.55) 0, rgba(255, 218, 142, 0) 190rpx),
    radial-gradient(circle at 88% 10%, rgba(108, 167, 225, 0.42) 0, rgba(108, 167, 225, 0) 210rpx),
    linear-gradient(180deg, #eaf4ff 0%, #f8efe0 54%, #eaf2ff 100%);
}

.home-shell {
  width: 100%;
  max-width: 650rpx;
  margin: 0 auto;
}

.player-strip {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  background: rgba(30, 75, 135, 0.16);
  box-shadow: 0 12rpx 30rpx rgba(26, 63, 120, 0.1);
  backdrop-filter: blur(12rpx);
  box-sizing: border-box;
}

.player-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  border: 4rpx solid #ffffff;
  background: linear-gradient(135deg, #315fb5 0%, #f0a641 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 800;
  box-shadow: 0 10rpx 22rpx rgba(28, 57, 112, 0.14);
  box-sizing: border-box;
}

.player-main {
  flex: 1;
  min-width: 0;
}

.player-name,
.player-title,
.token-label,
.token-value {
  display: block;
  line-height: 1.2;
}

.player-name {
  color: #17233f;
  font-size: 30rpx;
  font-weight: 800;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.player-title {
  display: inline-block;
  margin-top: 6rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #23856d 0%, #46a083 100%);
  font-size: 20rpx;
  font-weight: 700;
}

.player-token {
  min-width: 92rpx;
  padding: 8rpx 12rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(49, 95, 181, 0.12);
  text-align: center;
  box-sizing: border-box;
}

.seal-token {
  background: rgba(255, 246, 223, 0.9);
  border-color: rgba(240, 166, 65, 0.24);
}

.token-label {
  color: #59647a;
  font-size: 18rpx;
}

.token-value {
  margin-top: 4rpx;
  color: #18213d;
  font-size: 22rpx;
  font-weight: 800;
}

.hall-banner {
  position: relative;
  margin-top: 18rpx;
  padding: 22rpx 126rpx 22rpx 24rpx;
  min-height: 116rpx;
  border-radius: 22rpx;
  overflow: hidden;
  background:
    linear-gradient(135deg, rgba(49, 95, 181, 0.96) 0%, rgba(92, 125, 205, 0.94) 100%);
  box-shadow: 0 18rpx 38rpx rgba(28, 57, 112, 0.2);
  box-sizing: border-box;
}

.hall-banner::after {
  content: '';
  position: absolute;
  right: -22rpx;
  bottom: -42rpx;
  width: 168rpx;
  height: 168rpx;
  border-radius: 50%;
  border: 22rpx solid rgba(255, 255, 255, 0.16);
}

.hall-title,
.hall-rally {
  display: block;
  position: relative;
  z-index: 1;
}

.hall-title {
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.1;
}

.hall-rally {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 24rpx;
  line-height: 1.35;
}

.status-pill {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  z-index: 2;
  min-width: 124rpx;
  padding: 9rpx 14rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1.2;
  text-align: center;
  box-sizing: border-box;
  box-shadow: 0 8rpx 18rpx rgba(25, 45, 85, 0.16);
}

.status-pending {
  background: linear-gradient(135deg, #e45b58 0%, #f0a641 100%);
}

.status-done {
  background: linear-gradient(135deg, #23856d 0%, #46a083 100%);
}

.hero-card {
  position: relative;
  overflow: hidden;
  margin-top: 18rpx;
  padding: 28rpx 26rpx 26rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(240, 166, 65, 0.28);
  background:
    linear-gradient(180deg, rgba(255, 252, 242, 0.98) 0%, rgba(255, 238, 202, 0.98) 100%);
  box-shadow: 0 22rpx 46rpx rgba(151, 97, 28, 0.16);
  box-sizing: border-box;
}

.hero-card::before {
  content: '';
  position: absolute;
  top: -48rpx;
  right: -36rpx;
  width: 188rpx;
  height: 188rpx;
  border-radius: 50%;
  background: rgba(228, 91, 88, 0.08);
}

.hero-head {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-kicker,
.hero-title,
.hero-subtitle {
  display: block;
}

.hero-kicker {
  color: #9a621e;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1.2;
}

.hero-title {
  margin-top: 6rpx;
  color: #18213d;
  font-size: 54rpx;
  font-weight: 900;
  line-height: 1.04;
}

.hero-subtitle {
  margin-top: 10rpx;
  color: #59647a;
  font-size: 23rpx;
  line-height: 1.2;
}

.hero-seal {
  width: 94rpx;
  height: 94rpx;
  border-radius: 22rpx;
  background: #e45b58;
  color: #fff9ee;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  font-weight: 900;
  transform: rotate(5deg);
  box-shadow: 0 12rpx 24rpx rgba(228, 91, 88, 0.24);
}

.hint-row {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: space-between;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.hint-cell {
  position: relative;
  flex: 1;
  min-width: 0;
  height: 118rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.cell-hidden {
  background: rgba(255, 255, 255, 0.6);
  border: 2rpx dashed rgba(154, 98, 30, 0.32);
}

.cell-revealed {
  background: #ffffff;
  border: 2rpx solid rgba(49, 95, 181, 0.34);
  box-shadow: inset 0 0 0 6rpx rgba(49, 95, 181, 0.045);
}

.cell-index {
  position: absolute;
  top: 10rpx;
  left: 12rpx;
  color: rgba(89, 100, 122, 0.58);
  font-size: 20rpx;
  line-height: 1;
}

.hint-char {
  position: absolute;
  color: #315fb5;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1;
}

.hint-left { left: 14rpx; top: 50%; transform: translateY(-50%); }
.hint-right { right: 14rpx; top: 50%; transform: translateY(-50%); }
.hint-top { left: 50%; top: 10rpx; transform: translateX(-50%); }
.hint-bottom { left: 50%; bottom: 10rpx; transform: translateX(-50%); }
.hint-center { left: 50%; top: 50%; transform: translate(-50%, -50%); }

.hint-q {
  color: rgba(89, 100, 122, 0.42);
  font-size: 42rpx;
  font-weight: 700;
}

.hero-meta {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: space-between;
  gap: 10rpx;
  margin-bottom: 22rpx;
}

.hero-meta text {
  flex: 1;
  min-width: 0;
  padding: 8rpx 10rpx;
  border-radius: 999rpx;
  color: #59647a;
  background: rgba(255, 255, 255, 0.68);
  font-size: 21rpx;
  line-height: 1.2;
  text-align: center;
  box-sizing: border-box;
}

.primary-cta {
  position: relative;
  z-index: 1;
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  padding: 0;
  border: none;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #e45b58 0%, #f0a641 100%);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 900;
  box-shadow: 0 16rpx 30rpx rgba(228, 91, 88, 0.22);
}

.primary-cta::after {
  border: none;
}

.primary-cta:active,
.guide-trigger:active,
.mode-card:active,
.mini-link:active {
  opacity: 0.86;
  transform: translateY(2rpx);
}

.guide-trigger {
  position: relative;
  z-index: 1;
  min-height: 66rpx;
  margin-top: 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(49, 95, 181, 0.16);
  background: rgba(255, 255, 255, 0.68);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  box-sizing: border-box;
}

.guide-trigger-icon {
  width: 34rpx;
  height: 34rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #315fb5 0%, #f0a641 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1;
}

.guide-trigger-text {
  color: #315fb5;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.2;
}

.mode-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.mode-card {
  position: relative;
  min-width: 0;
  min-height: 164rpx;
  padding: 18rpx 10rpx 16rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 12rpx 26rpx rgba(28, 57, 112, 0.08);
  box-sizing: border-box;
}

.action-hint { background: linear-gradient(180deg, #ffffff 0%, #edf3ff 100%); }
.action-practice { background: linear-gradient(180deg, #ffffff 0%, #eef8f5 100%); }
.action-two { background: linear-gradient(180deg, #ffffff 0%, #fff3d7 100%); }

.mode-badge {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  min-width: 48rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: #e45b58;
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 800;
  line-height: 1.2;
  text-align: center;
  box-sizing: border-box;
}

.mode-icon {
  width: 62rpx;
  height: 62rpx;
  margin: 8rpx auto 12rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #315fb5 0%, #5f73c7 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 900;
  box-shadow: 0 10rpx 18rpx rgba(49, 95, 181, 0.16);
}

.action-practice .mode-icon {
  background: linear-gradient(135deg, #23856d 0%, #46a083 100%);
}

.action-two .mode-icon {
  background: linear-gradient(135deg, #f0a641 0%, #e45b58 100%);
}

.mode-name,
.mode-desc {
  display: block;
  text-align: center;
}

.mode-name {
  color: #18213d;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.2;
}

.mode-desc {
  margin-top: 8rpx;
  color: #59647a;
  font-size: 20rpx;
  line-height: 1.22;
}

.progress-panel {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.stamp-card {
  min-width: 0;
  padding: 16rpx 10rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(49, 95, 181, 0.14);
  background: rgba(255, 255, 255, 0.66);
  text-align: center;
  box-sizing: border-box;
}

.stamp-title,
.stamp-value {
  display: block;
  line-height: 1.2;
}

.stamp-title {
  color: #59647a;
  font-size: 19rpx;
}

.stamp-value {
  margin-top: 8rpx;
  color: #18213d;
  font-size: 22rpx;
  font-weight: 900;
}

.mini-links {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.mini-link {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  min-height: 72rpx;
  border-radius: 18rpx;
  background: rgba(30, 75, 135, 0.12);
  border: 1rpx solid rgba(49, 95, 181, 0.12);
  box-sizing: border-box;
}

.mini-icon {
  width: 42rpx;
  height: 42rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #315fb5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 900;
}

.mini-text {
  color: #18213d;
  font-size: 24rpx;
  font-weight: 800;
}

.guide-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
  padding: calc(90rpx + env(safe-area-inset-top)) 30rpx calc(50rpx + env(safe-area-inset-bottom));
  background: rgba(24, 33, 61, 0.5);
  display: flex;
  align-items: flex-start;
  justify-content: center;
  box-sizing: border-box;
}

.guide-card {
  width: 100%;
  max-width: 650rpx;
  max-height: 82vh;
  overflow-y: auto;
  padding: 28rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(240, 166, 65, 0.32);
  background: linear-gradient(180deg, #fffdf7 0%, #fff0d6 100%);
  box-shadow: 0 28rpx 70rpx rgba(24, 33, 61, 0.28);
  box-sizing: border-box;
}

.guide-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.guide-kicker,
.guide-title,
.guide-section-title,
.guide-tip-title,
.guide-tip-text {
  display: block;
  line-height: 1.25;
}

.guide-kicker {
  color: #9a621e;
  font-size: 22rpx;
  font-weight: 900;
}

.guide-title {
  margin-top: 6rpx;
  color: #18213d;
  font-size: 36rpx;
  font-weight: 900;
}

.guide-close {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  color: #fff9ee;
  background: #e45b58;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
  flex-shrink: 0;
  transform: rotate(5deg);
  box-shadow: 0 8rpx 18rpx rgba(228, 91, 88, 0.2);
}

.guide-section {
  padding: 20rpx;
  margin-bottom: 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.66);
  border: 1rpx solid rgba(240, 166, 65, 0.2);
  box-sizing: border-box;
}

.guide-step {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-bottom: 16rpx;
}

.guide-step:last-child {
  margin-bottom: 0;
}

.guide-step-num {
  width: 42rpx;
  height: 42rpx;
  border-radius: 14rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #315fb5 0%, #f0a641 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 900;
  flex-shrink: 0;
}

.guide-step-text {
  flex: 1;
  min-width: 0;
  color: #18213d;
  font-size: 25rpx;
  line-height: 1.45;
}

.guide-section-title {
  color: #18213d;
  font-size: 28rpx;
  font-weight: 900;
  margin-bottom: 16rpx;
}

.guide-colors {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.guide-color-item {
  min-width: 0;
  min-height: 56rpx;
  padding: 10rpx 12rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #18213d;
  font-size: 22rpx;
  line-height: 1.25;
  display: flex;
  align-items: center;
  gap: 8rpx;
  box-sizing: border-box;
}

.color-dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.color-correct { background: #23856d; }
.color-pinyin { background: #315fb5; }
.color-present { background: #d88c2e; }
.color-partial { background: #7a67b7; }
.color-absent { background: #8b93a1; }

.guide-tip {
  padding: 20rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #ffffff 0%, #eef8f5 100%);
  border: 1rpx solid rgba(35, 133, 109, 0.18);
  box-sizing: border-box;
}

.guide-tip-title {
  color: #23856d;
  font-size: 26rpx;
  font-weight: 900;
}

.guide-tip-text {
  margin-top: 10rpx;
  color: #59647a;
  font-size: 24rpx;
  line-height: 1.45;
}
