.page {
  min-height: 100vh;
  background:
    linear-gradient(180deg, #f1f5ff 0%, #e4ebfb 54%, #edf3ff 100%),
    repeating-linear-gradient(90deg, rgba(55, 86, 152, 0.032) 0, rgba(55, 86, 152, 0.032) 1rpx, transparent 1rpx, transparent 26rpx);
  color: #18213d;
  box-sizing: border-box;
  padding: calc(86rpx + env(safe-area-inset-top)) 30rpx 64rpx;
}

.home-shell {
  width: 100%;
  max-width: 650rpx;
  margin: 0 auto;
}

.topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.title-block {
  flex: 1;
  min-width: 0;
}

.brand-title {
  display: block;
  color: #18213d;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: 0;
}

.date-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
  color: #59647a;
  font-size: 24rpx;
}

.today-date,
.puzzle-number {
  display: inline-block;
  line-height: 1.2;
}

.puzzle-number {
  padding-left: 12rpx;
  border-left: 1rpx solid rgba(89, 100, 122, 0.3);
}

.status-pill {
  flex-shrink: 0;
  min-width: 168rpx;
  max-width: 188rpx;
  min-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.2;
  text-align: center;
  white-space: nowrap;
  box-sizing: border-box;
  box-shadow: 0 8rpx 18rpx rgba(28, 57, 112, 0.08);
}

.status-pill::before {
  content: '';
  width: 10rpx;
  height: 10rpx;
  margin-right: 8rpx;
  border-radius: 999rpx;
  background: currentColor;
  opacity: 0.78;
}

.status-pending {
  color: #315fb5;
  background: rgba(237, 243, 255, 0.9);
  border: 1rpx solid rgba(49, 95, 181, 0.24);
}

.status-done {
  color: #23856d;
  background: rgba(233, 247, 245, 0.9);
  border: 1rpx solid rgba(35, 133, 109, 0.22);
}

.puzzle-paper {
  position: relative;
  overflow: hidden;
  padding: 30rpx 28rpx 28rpx;
  border: 1rpx solid rgba(55, 86, 152, 0.18);
  border-radius: 16rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(237, 243, 255, 0.98) 100%);
  box-shadow: 0 18rpx 42rpx rgba(28, 57, 112, 0.1);
  box-sizing: border-box;
}

.puzzle-paper::before {
  content: '';
  position: absolute;
  top: 18rpx;
  left: 20rpx;
  right: 20rpx;
  height: 2rpx;
  background: linear-gradient(90deg, #315fb5, #f0a641, #e45b58);
  opacity: 0.92;
}

.paper-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.paper-kicker {
  color: #59647a;
  font-size: 26rpx;
  font-weight: 600;
}

.paper-seal {
  width: 58rpx;
  height: 58rpx;
  border: 2rpx solid rgba(228, 91, 88, 0.58);
  color: #e45b58;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.05;
  box-sizing: border-box;
}

.hint-row {
  display: flex;
  justify-content: space-between;
  gap: 14rpx;
  margin-bottom: 22rpx;
}

.hint-cell {
  position: relative;
  flex: 1;
  min-width: 0;
  height: 118rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.cell-hidden {
  background: #edf3ff;
  border: 2rpx dashed rgba(89, 100, 122, 0.26);
}

.cell-revealed {
  background: #ffffff;
  border: 2rpx solid rgba(49, 95, 181, 0.36);
  box-shadow: inset 0 0 0 6rpx rgba(49, 95, 181, 0.045);
}

.cell-index {
  position: absolute;
  top: 10rpx;
  left: 12rpx;
  color: rgba(89, 100, 122, 0.58);
  font-size: 20rpx;
  line-height: 1;
}

.hint-char {
  position: absolute;
  color: #315fb5;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1;
}

.hint-left {
  left: 14rpx;
  top: 50%;
  transform: translateY(-50%);
}

.hint-right {
  right: 14rpx;
  top: 50%;
  transform: translateY(-50%);
}

.hint-top {
  left: 50%;
  top: 10rpx;
  transform: translateX(-50%);
}

.hint-bottom {
  left: 50%;
  bottom: 10rpx;
  transform: translateX(-50%);
}

.hint-center {
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
}

.hint-q {
  color: rgba(89, 100, 122, 0.45);
  font-size: 42rpx;
  font-weight: 600;
}

.paper-meta {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  color: #59647a;
  font-size: 22rpx;
  line-height: 1.2;
  margin-bottom: 24rpx;
}

.paper-meta text {
  min-width: 0;
  text-align: center;
}

.primary-cta {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  border: none;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #315fb5 0%, #5f73c7 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 24rpx rgba(49, 95, 181, 0.18);
}

.primary-cta::after {
  border: none;
}

.primary-cta:active {
  opacity: 0.88;
  transform: translateY(2rpx);
}

.secondary-grid {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.secondary-action {
  flex: 1;
  min-width: 0;
  min-height: 132rpx;
  padding: 18rpx 12rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(55, 86, 152, 0.16);
  background: rgba(255, 255, 255, 0.86);
  box-sizing: border-box;
  box-shadow: 0 8rpx 22rpx rgba(28, 57, 112, 0.06);
}

.secondary-action:active {
  transform: translateY(2rpx);
  opacity: 0.88;
}

.action-name,
.action-desc {
  display: block;
  text-align: center;
}

.action-name {
  color: #18213d;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.28;
  min-height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  word-break: break-all;
}

.action-desc {
  margin-top: 10rpx;
  color: #59647a;
  font-size: 21rpx;
  line-height: 1.25;
}

.action-hint {
  border-top: 5rpx solid #315fb5;
}

.action-practice {
  border-top: 5rpx solid #5f73c7;
}

.action-two {
  border-top: 5rpx solid #f0a641;
}

.retention-strip {
  margin-top: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 14rpx;
  background: rgba(237, 243, 255, 0.92);
  color: #18213d;
  border: 1rpx solid rgba(49, 95, 181, 0.14);
  box-sizing: border-box;
}

.note-label {
  display: block;
  color: #315fb5;
  font-size: 22rpx;
  line-height: 1.2;
  margin-bottom: 8rpx;
}

.note-text {
  display: block;
  font-size: 26rpx;
  line-height: 1.45;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.status-chip {
  display: inline-block;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  color: #59647a;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(49, 95, 181, 0.14);
  font-size: 21rpx;
  line-height: 1.2;
}

.quiet-links {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.quiet-link {
  flex: 1;
  min-width: 0;
  padding: 18rpx 12rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.62);
  border: 1rpx solid rgba(55, 86, 152, 0.14);
  box-sizing: border-box;
}

.quiet-link:active {
  opacity: 0.8;
}

.quiet-link.muted {
  opacity: 0.62;
}

.quiet-title,
.quiet-desc {
  display: block;
  text-align: center;
}

.quiet-title {
  color: #18213d;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.3;
  min-height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  word-break: break-all;
}

.quiet-desc {
  margin-top: 8rpx;
  color: #59647a;
  font-size: 20rpx;
  line-height: 1.2;
}

.first-play {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.56);
  border: 1rpx solid rgba(55, 86, 152, 0.14);
  box-sizing: border-box;
}

.first-play-title {
  display: block;
  color: #315fb5;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.2;
  margin-bottom: 6rpx;
}

.first-play-text {
  display: block;
  color: #59647a;
  font-size: 22rpx;
  line-height: 1.45;
}
