/* ========== 页面布局 ========== */
.page {
  min-height: 100vh;
  padding: calc(72rpx + env(safe-area-inset-top)) 24rpx 280rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 14% 8%, rgba(255, 218, 142, 0.55) 0, rgba(255, 218, 142, 0) 190rpx),
    radial-gradient(circle at 88% 10%, rgba(108, 167, 225, 0.42) 0, rgba(108, 167, 225, 0) 210rpx),
    linear-gradient(180deg, #eaf4ff 0%, #f8efe0 54%, #eaf2ff 100%);
  color: #18213d;
}

/* ========== 头部 ========== */
.header {
  position: relative;
  width: 100%;
  max-width: 650rpx;
  min-height: 118rpx;
  margin: 0 auto 18rpx;
  padding: 22rpx 126rpx 22rpx 24rpx;
  border-radius: 22rpx;
  overflow: hidden;
  background: linear-gradient(135deg, rgba(49, 95, 181, 0.96) 0%, rgba(92, 125, 205, 0.94) 100%);
  box-shadow: 0 18rpx 38rpx rgba(28, 57, 112, 0.2);
  box-sizing: border-box;
}

.header::after {
  content: '';
  position: absolute;
  right: -22rpx;
  bottom: -42rpx;
  width: 168rpx;
  height: 168rpx;
  border-radius: 50%;
  border: 22rpx solid rgba(255, 255, 255, 0.16);
}

.header-title {
  position: relative;
  z-index: 1;
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.12;
}

.header-info {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: flex-start;
  align-items: center;
  gap: 12rpx;
  margin-top: 14rpx;
}

.puzzle-num {
  color: rgba(255, 255, 255, 0.86);
  font-size: 24rpx;
  line-height: 1.2;
}

.practice-badge {
  padding: 5rpx 14rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #e45b58 0%, #f0a641 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.36);
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.2;
}

/* ========== 部首提示条 ========== */
.hint-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  width: 100%;
  max-width: 650rpx;
  margin: 0 auto 12rpx;
  padding: 12rpx 18rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(240, 166, 65, 0.2);
  background: rgba(255, 246, 223, 0.74);
  box-sizing: border-box;
}

.hint-bar-icon {
  width: 42rpx;
  height: 42rpx;
  border-radius: 12rpx;
  color: #fff9ee;
  background: #e45b58;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1;
  transform: rotate(4deg);
}

.hint-bar-label {
  color: #315fb5;
  font-size: 23rpx;
  font-weight: 600;
  line-height: 1.2;
}

.hint-row {
  display: flex;
  gap: 12rpx;
  justify-content: center;
  margin: 0 auto 18rpx;
  max-width: 650rpx;
}

.hint-cell {
  width: 112rpx;
  height: 112rpx;
  border-radius: 18rpx;
  border: 2rpx dashed rgba(154, 98, 30, 0.3);
  background: rgba(255, 255, 255, 0.64);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-sizing: border-box;
}

.hint-char {
  position: absolute;
  color: #315fb5;
  font-weight: 700;
  line-height: 1;
}

.hint-left   { left: 12rpx; top: 50%; transform: translateY(-50%); font-size: 32rpx; }
.hint-right  { right: 12rpx; top: 50%; transform: translateY(-50%); font-size: 32rpx; }
.hint-top    { top: 8rpx; left: 50%; transform: translateX(-50%); font-size: 28rpx; }
.hint-bottom { bottom: 8rpx; left: 50%; transform: translateX(-50%); font-size: 28rpx; }
.hint-center { top: 50%; left: 50%; transform: translate(-50%,-50%); font-size: 34rpx; }

.hint-q {
  color: rgba(89, 100, 122, 0.46);
  font-size: 38rpx;
  font-weight: 600;
}

/* ========== 游戏网格 ========== */
.grid {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin: 8rpx auto;
  max-width: 650rpx;
}

.grid-row {
  display: flex;
  justify-content: center;
  gap: 8rpx;
}

.char-cell {
  width: 112rpx;
  height: 112rpx;
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(55, 86, 152, 0.2);
  background-color: rgba(255, 255, 255, 0.86);
  color: #18213d;
  position: relative;
  box-sizing: border-box;
  box-shadow: 0 8rpx 18rpx rgba(28, 57, 112, 0.06);
  transition: background-color 0.2s, border-color 0.2s, opacity 0.2s;
}

.char-text {
  color: inherit;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.1;
}

.pinyin-text {
  color: rgba(89, 100, 122, 0.78);
  font-size: 20rpx;
  line-height: 1.2;
  margin-top: 4rpx;
}

.status-label {
  color: rgba(89, 100, 122, 0.82);
  font-size: 16rpx;
  line-height: 1.1;
  margin-top: 3rpx;
}

.char-cell.correct,
.char-cell.pinyin,
.char-cell.present,
.char-cell.partial,
.char-cell.absent {
  color: #ffffff;
}

.char-cell.correct .pinyin-text,
.char-cell.pinyin .pinyin-text,
.char-cell.present .pinyin-text,
.char-cell.partial .pinyin-text,
.char-cell.absent .pinyin-text,
.char-cell.correct .status-label,
.char-cell.pinyin .status-label,
.char-cell.present .status-label,
.char-cell.partial .status-label,
.char-cell.absent .status-label {
  color: rgba(255, 255, 255, 0.82);
}

.char-cell.correct { background-color: #23856d; border-color: #1c6b58; }
.char-cell.pinyin { background-color: #315fb5; border-color: #274c96; }
.char-cell.present { background-color: #d88c2e; border-color: #9a621e; }
.char-cell.partial { background-color: #7a67b7; border-color: #6d5da3; }
.char-cell.absent { background-color: #8b93a1; border-color: #737b8d; }

.char-cell.empty-cell {
  border-color: rgba(89, 100, 122, 0.22);
  background-color: rgba(255, 255, 255, 0.42);
}

/* ========== 提示系统 ========== */
.hint-section {
  width: 100%;
  max-width: 620rpx;
  margin: 10rpx auto 0;
}

.hint-toggle {
  padding: 16rpx 20rpx;
  border-radius: 18rpx;
  border: 2rpx dashed rgba(240, 166, 65, 0.5);
  color: #9a621e;
  background: rgba(255, 243, 215, 0.54);
  font-size: 25rpx;
  line-height: 1.2;
  text-align: center;
}

.hint-toggle:active {
  opacity: 0.86;
}

.hint-messages {
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(240, 166, 65, 0.22);
  background: rgba(255, 243, 215, 0.62);
}

.hint-msg {
  display: block;
  color: #9a621e;
  font-size: 24rpx;
  line-height: 1.55;
  margin-bottom: 6rpx;
}

.hint-msg:last-child {
  margin-bottom: 0;
}

.round-feedback {
  width: 100%;
  max-width: 620rpx;
  margin: 10rpx auto 0;
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  color: #315fb5;
  background: rgba(237, 243, 255, 0.86);
  border: 1rpx solid rgba(49, 95, 181, 0.14);
  font-size: 24rpx;
  line-height: 1.35;
  text-align: center;
  box-sizing: border-box;
}

/* ========== 输入区域 ========== */
.input-area {
  width: 100%;
  max-width: 620rpx;
  margin: 12rpx auto 0;
  position: relative;
}

.input-boxes {
  display: flex;
  gap: 8rpx;
  justify-content: center;
  margin-bottom: 10rpx;
}

.input-char-box {
  width: 112rpx;
  height: 112rpx;
  border-radius: 18rpx;
  border: 2rpx dashed rgba(49, 95, 181, 0.42);
  background-color: rgba(255, 255, 255, 0.72);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-sizing: border-box;
  transition: border-color 0.2s, background-color 0.2s;
}

.input-char-box.has-char {
  border-style: solid;
  border-color: rgba(49, 95, 181, 0.58);
  background-color: #ffffff;
}

.input-char-box.active {
  border-color: rgba(240, 166, 65, 0.72);
  box-shadow: inset 0 0 0 5rpx rgba(240, 166, 65, 0.08);
}

.input-char-text {
  color: #18213d;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1;
}

.input-guide {
  margin: 0 auto 8rpx;
  color: rgba(89, 100, 122, 0.78);
  font-size: 22rpx;
  line-height: 1.25;
  text-align: center;
}

.cursor-bar {
  position: absolute;
  width: 3rpx;
  height: 48rpx;
  background-color: #d88c2e;
  animation: blink 1s infinite;
}

@keyframes blink {
  0%, 50% { opacity: 1; }
  51%, 100% { opacity: 0; }
}

.input-status {
  text-align: center;
  margin-bottom: 8rpx;
}

.input-status-text {
  padding: 5rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.2;
}

.input-status-text.valid {
  color: #315fb5;
  background: #edf3ff;
}

.input-status-text.loose {
  color: #9a621e;
  background: #fff3d7;
}

.input-status-text.duplicate {
  color: #e45b58;
  background: #fff0ef;
}

.keyboard-input {
  position: absolute;
  left: 50%;
  top: 0;
  width: 2rpx;
  height: 2rpx;
  opacity: 0;
}

/* ========== 操作按钮 ========== */
.actions {
  position: fixed;
  left: 50%;
  bottom: calc(132rpx + env(safe-area-inset-bottom));
  transform: translateX(-50%);
  z-index: 70;
  display: flex;
  gap: 12rpx;
  margin: 0 auto;
  width: calc(100% - 96rpx);
  max-width: 600rpx;
  padding: 10rpx;
  border-radius: 999rpx;
  background: rgba(234, 244, 255, 0.88);
  box-shadow: 0 16rpx 36rpx rgba(28, 57, 112, 0.16);
  backdrop-filter: blur(12rpx);
  box-sizing: border-box;
}

.btn {
  flex: 1;
  min-height: 82rpx;
  padding: 0;
  border-radius: 999rpx;
  font-size: 30rpx;
  line-height: 82rpx;
  text-align: center;
  border: none;
  box-sizing: border-box;
}

.btn::after {
  border: none;
}

.btn:active {
  opacity: 0.86;
}

.btn-submit {
  flex: 2;
  background: linear-gradient(135deg, #e45b58 0%, #f0a641 100%);
  color: #ffffff;
  font-weight: 900;
  box-shadow: 0 16rpx 30rpx rgba(228, 91, 88, 0.22);
}

.btn-submit.disabled {
  background: rgba(237, 243, 255, 0.86);
  color: rgba(49, 95, 181, 0.42);
  border: 1rpx solid rgba(49, 95, 181, 0.14);
  box-shadow: none;
}

.btn-clear {
  background-color: rgba(255, 255, 255, 0.52);
  border: 1rpx solid rgba(55, 86, 152, 0.24);
  color: #59647a;
}

/* ========== 胜利/失败弹窗 ========== */
.praise-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(28, 57, 112, 0.58);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  padding: 40rpx;
  box-sizing: border-box;
  animation: fadeIn 0.25s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.praise-card {
  width: 100%;
  max-width: 600rpx;
  padding: 42rpx 34rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(240, 166, 65, 0.28);
  background: linear-gradient(180deg, rgba(255, 252, 242, 0.98) 0%, rgba(255, 238, 202, 0.98) 100%);
  box-shadow: 0 24rpx 62rpx rgba(151, 97, 28, 0.22);
  text-align: center;
  box-sizing: border-box;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(60rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.praise-emoji {
  width: 68rpx;
  height: 68rpx;
  margin: 0 auto 12rpx;
  border-radius: 18rpx;
  border: none;
  background: #e45b58;
  color: #fff9ee;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
}

.praise-text {
  color: #18213d;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.35;
}

.answer-reveal {
  margin: 18rpx 0;
  padding: 20rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.68);
  box-sizing: border-box;
}

.answer-label {
  color: #59647a;
  font-size: 26rpx;
}

.answer-text {
  display: block;
  color: #315fb5;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.2;
  margin: 8rpx 0;
  letter-spacing: 0;
}

.answer-pinyin {
  display: block;
  color: #59647a;
  font-size: 26rpx;
  line-height: 1.3;
  margin-bottom: 8rpx;
}

.answer-meaning {
  display: block;
  color: #59647a;
  font-size: 25rpx;
  line-height: 1.5;
}

.emoji-grid {
  margin: 12rpx 0;
}

.emoji-line {
  display: block;
  font-size: 38rpx;
  line-height: 1.5;
  letter-spacing: 0;
}

.result-review {
  margin-top: 12rpx;
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  color: #59647a;
  background: rgba(255, 255, 255, 0.68);
  border: 1rpx solid rgba(49, 95, 181, 0.12);
  font-size: 24rpx;
  line-height: 1.4;
}

.btn-share {
  width: 100%;
  min-height: 82rpx;
  margin-top: 18rpx;
  padding: 0;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #e45b58 0%, #f0a641 100%);
  color: #ffffff;
  font-size: 30rpx;
  line-height: 82rpx;
  font-weight: 900;
  box-shadow: 0 16rpx 30rpx rgba(228, 91, 88, 0.2);
}

.btn-share::after {
  border: none;
}

.btn-back-home {
  margin-top: 16rpx;
  padding: 16rpx 0;
  color: #59647a;
  font-size: 26rpx;
  line-height: 1.2;
  text-align: center;
}

.btn-back-home:active {
  color: #315fb5;
}

.streak-badge {
  margin-top: 14rpx;
  color: #9a621e;
  font-size: 26rpx;
}

@keyframes bounceIn {
  0% { transform: scale(0.94); opacity: 0.6; }
  100% { transform: scale(1); opacity: 1; }
}

.win-row .char-cell {
  animation: bounceIn 0.28s ease both;
}

.win-row .char-cell:nth-child(1) { animation-delay: 0s; }
.win-row .char-cell:nth-child(2) { animation-delay: 0.05s; }
.win-row .char-cell:nth-child(3) { animation-delay: 0.1s; }
.win-row .char-cell:nth-child(4) { animation-delay: 0.15s; }

.footer-hint {
  margin: 28rpx auto 0;
  color: #59647a;
  font-size: 25rpx;
  line-height: 1.4;
  text-align: center;
}
