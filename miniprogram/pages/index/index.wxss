/* ========== 页面布局 ========== */
.page {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding: calc(140rpx + env(safe-area-inset-top)) 20rpx 16rpx;
  box-sizing: border-box;
}

/* ========== 头部 ========== */
.header {
  text-align: center;
  margin-bottom: 6rpx;
}
.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #3B82F6;
}
.header-info {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20rpx;
  margin-top: 6rpx;
}
.puzzle-num {
  font-size: 24rpx;
  color: #64748B;
}
.practice-badge {
  font-size: 20rpx;
  color: #F59E0B;
  background: rgba(245,158,11,0.15);
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  margin-left: 10rpx;
}

/* ========== 部首提示条 ========== */
.hint-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin: 10rpx 0 6rpx;
}
.hint-bar-icon {
  font-size: 22rpx;
}
.hint-bar-label {
  font-size: 22rpx;
  color: #22C55E;
}

/* 部首格 — 与首页一致的定位展示 */
.hint-row {
  display: flex;
  gap: 12rpx;
  justify-content: center;
  margin-bottom: 10rpx;
}
.hint-cell {
  width: 104rpx;
  height: 104rpx;
  border-radius: 16rpx;
  border: 2rpx solid #334155;
  background: #0F172A;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
.hint-char {
  position: absolute;
  color: #22C55E;
  font-weight: bold;
  opacity: 0.7;
  animation: hintPulse 2s ease-in-out infinite;
}
.hint-left   { left: 6rpx; top: 50%; transform: translateY(-50%); font-size: 32rpx; }
.hint-right  { right: 6rpx; top: 50%; transform: translateY(-50%); font-size: 32rpx; }
.hint-top    { top: 2rpx; left: 50%; transform: translateX(-50%); font-size: 28rpx; }
.hint-bottom { bottom: 2rpx; left: 50%; transform: translateX(-50%); font-size: 28rpx; }
.hint-center { top: 50%; left: 50%; transform: translate(-50%,-50%); font-size: 34rpx; }
.hint-q {
  font-size: 36rpx;
  color: #475569;
}
@keyframes hintPulse {
  0%, 100% { opacity: 0.5; }
  50% { opacity: 0.9; }
}

/* ========== 游戏网格 ========== */
.grid {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin: 6rpx 0;
}
.grid-row {
  display: flex;
  gap: 8rpx;
}

/* 字符单元格 */
.char-cell {
  width: 110rpx;
  height: 110rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #475569;
  background-color: #1E293B;
  transition: all 0.3s ease;
  position: relative;
}
.char-text {
  font-size: 42rpx;
  font-weight: bold;
  line-height: 1.2;
}
.pinyin-text {
  font-size: 20rpx;
  color: #64748B;
  margin-top: 4rpx;
}
.status-label {
  font-size: 16rpx;
  color: rgba(255,255,255,0.55);
  margin-top: 2rpx;
  line-height: 1.1;
}

/* 颜色状态 */
.char-cell.correct .status-label,
.char-cell.pinyin .status-label,
.char-cell.present .status-label,
.char-cell.partial .status-label,
.char-cell.absent .status-label { color: rgba(255,255,255,0.65); }
.char-cell.correct { background-color: #22c55e; border-color: #16a34a; }
.char-cell.correct .char-text { color: #F1F5F9; }
.char-cell.correct .pinyin-text { color: rgba(255,255,255,0.8); }

.char-cell.pinyin { background-color: #3b82f6; border-color: #2563eb; }
.char-cell.pinyin .char-text { color: #F1F5F9; }
.char-cell.pinyin .pinyin-text { color: rgba(255,255,255,0.8); }

.char-cell.present { background-color: #EAB308; border-color: #ca8a04; }
.char-cell.present .char-text { color: #F1F5F9; }
.char-cell.present .pinyin-text { color: rgba(255,255,255,0.8); }

.char-cell.partial { background-color: #a855f7; border-color: #9333ea; }
.char-cell.partial .char-text { color: #F1F5F9; }
.char-cell.partial .pinyin-text { color: rgba(255,255,255,0.8); }

.char-cell.absent { background-color: #9ca3af; border-color: #6b7280; }
.char-cell.absent .char-text { color: #F1F5F9; }
.char-cell.absent .pinyin-text { color: rgba(255,255,255,0.8); }

/* 空行 */
.char-cell.empty-cell {
  border-color: #334155;
  background-color: #0F172A;
}

/* ========== 提示系统 ========== */
.hint-section {
  width: 100%;
  max-width: 620rpx;
  margin-top: 8rpx;
}
.hint-toggle {
  text-align: center;
  padding: 14rpx;
  color: #F59E0B;
  font-size: 26rpx;
  border: 2rpx dashed #F59E0B;
  border-radius: 12rpx;
  opacity: 0.8;
  transition: opacity 0.2s;
}
.hint-toggle:active { opacity: 1; }
.hint-messages {
  background: rgba(245, 158, 11, 0.1);
  border: 1rpx solid rgba(245, 158, 11, 0.2);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}
.hint-msg {
  display: block;
  font-size: 24rpx;
  color: #FCD34D;
  line-height: 1.6;
  margin-bottom: 6rpx;
}
.hint-msg:last-child { margin-bottom: 0; }

/* ========== 输入区域 ========== */
.input-area {
  width: 100%;
  max-width: 620rpx;
  margin-top: 10rpx;
}

/* 4 个展示格 */
.input-boxes {
  display: flex;
  gap: 8rpx;
  justify-content: center;
  margin-bottom: 10rpx;
}
.input-char-box {
  width: 110rpx;
  height: 110rpx;
  border-radius: 16rpx;
  border: 3rpx dashed #3B82F6;
  background-color: #1E293B;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: border-color 0.2s, background-color 0.2s;
}
.input-char-box.has-char {
  border-style: solid;
  border-color: #60A5FA;
  background-color: #1E3A5F;
}
.input-char-box.active {
  border-color: #EAB308;
  box-shadow: 0 0 12rpx rgba(234, 179, 8, 0.2);
}
.input-char-text {
  font-size: 42rpx;
  font-weight: bold;
  color: #F1F5F9;
}

/* 闪烁光标 */
.cursor-bar {
  position: absolute;
  width: 3rpx;
  height: 48rpx;
  background-color: #EAB308;
  animation: blink 1s infinite;
}
@keyframes blink {
  0%, 50% { opacity: 1; }
  51%, 100% { opacity: 0; }
}

/* 输入状态提示 */
.input-status {
  text-align: center;
  margin-bottom: 6rpx;
}
.input-status-text {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}
.input-status-text.valid { color: #22C55E; background: rgba(34,197,94,0.1); }
.input-status-text.loose { color: #F59E0B; background: rgba(245,158,11,0.1); }
.input-status-text.duplicate { color: #EF4444; background: rgba(239,68,68,0.1); }

/* 可见输入框 */
.visible-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #334155;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #F1F5F9;
  background-color: #1E293B;
  box-sizing: border-box;
}

/* ========== 操作按钮 ========== */
.actions {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
  width: 100%;
  max-width: 600rpx;
}
.btn {
  flex: 1;
  border-radius: 12rpx;
  padding: 18rpx 0;
  font-size: 30rpx;
  text-align: center;
  border: none;
}
.btn:active { opacity: 0.8; }

.btn-submit {
  flex: 2;
  background-color: #3B82F6;
  color: #F1F5F9;
  font-weight: bold;
}
.btn-submit.disabled {
  background-color: #334155;
  color: #475569;
}

.btn-clear {
  background-color: transparent;
  border: 2rpx solid #475569;
  color: #94A3B8;
}
.btn-icon {
  font-size: 28rpx;
  margin-right: 4rpx;
}

/* ========== 胜利/失败弹窗 ========== */
.praise-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  animation: fadeIn 0.3s ease;
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.praise-card {
  background-color: #0F172A;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  width: 85%;
  max-width: 600rpx;
  text-align: center;
  animation: slideUp 0.4s ease;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.15);
}
@keyframes slideUp {
  from { transform: translateY(100rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.praise-emoji {
  font-size: 80rpx;
  margin-bottom: 10rpx;
}
.praise-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #3B82F6;
  margin-bottom: 10rpx;
  line-height: 1.5;
}

/* 答案展示 */
.answer-reveal {
  margin: 10rpx 0;
  padding: 20rpx;
  background-color: #1E293B;
  border-radius: 12rpx;
}
.answer-label {
  font-size: 28rpx;
  color: #64748B;
}
.answer-text {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: #3B82F6;
  margin: 10rpx 0;
  letter-spacing: 16rpx;
}
.answer-pinyin {
  display: block;
  font-size: 28rpx;
  color: #64748B;
  margin-bottom: 10rpx;
}
.answer-meaning {
  display: block;
  font-size: 26rpx;
  color: #94A3B8;
}

/* Emoji 战绩 */
.emoji-grid {
  margin: 10rpx 0;
}
.emoji-line {
  display: block;
  font-size: 44rpx;
  letter-spacing: 8rpx;
  line-height: 1.6;
}

/* 分享按钮 */
.btn-share {
  background-color: #3B82F6;
  color: #F1F5F9;
  border-radius: 12rpx;
  padding: 18rpx 0;
  font-size: 32rpx;
  margin-top: 20rpx;
  width: 100%;
}

.btn-back-home {
  margin-top: 20rpx;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #64748B;
  text-align: center;
}
.btn-back-home:active {
  color: #3B82F6;
}

.streak-badge {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #f59e0b;
}

/* ========== 胜利动画 ========== */
@keyframes bounceIn {
  0% { transform: scale(0.3); opacity: 0; }
  50% { transform: scale(1.08); }
  70% { transform: scale(0.95); }
  100% { transform: scale(1); opacity: 1; }
}
.win-row .char-cell {
  animation: bounceIn 0.5s ease both;
}
.win-row .char-cell:nth-child(1) { animation-delay: 0s; }
.win-row .char-cell:nth-child(2) { animation-delay: 0.1s; }
.win-row .char-cell:nth-child(3) { animation-delay: 0.2s; }
.win-row .char-cell:nth-child(4) { animation-delay: 0.3s; }

/* 庆祝粒子 */
@keyframes confetti {
  0% { transform: translateY(0) rotate(0deg); opacity: 1; }
  100% { transform: translateY(-400rpx) rotate(720deg); opacity: 0; }
}
.praise-overlay::before {
  content: '🎉🎊🏆✨🌟';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 40rpx;
  pointer-events: none;
  animation: confetti 2s ease-out both;
  white-space: nowrap;
}

/* ========== 底部提示 ========== */
.footer-hint {
  margin-top: 40rpx;
  font-size: 26rpx;
  color: #64748B;
  text-align: center;
}

/* 为固定底栏留空间 */
.page { padding-bottom: 120rpx; }
