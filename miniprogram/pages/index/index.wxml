<!-- 部首猜词 — 主游戏页面 -->
<view class="page">

  <!-- 顶部信息栏 -->
  <view class="header">
    <view class="header-title">部首猜词</view>
    <view class="header-info">
      <text class="puzzle-num">{{dateDisplay}}</text>
      <text class="practice-badge" wx:if="{{practiceMode}}">自由练习</text>
      <text class="practice-badge" wx:elif="{{rankingNotice}}">{{rankingNotice}}</text>
    </view>
  </view>

  <!-- 部首提示 — 按结构位置定位，与首页一致 -->
  <view class="hint-bar">
    <text class="hint-bar-icon">首</text>
    <text class="hint-bar-label">{{hintTitle}}</text>
  </view>
  <view class="hint-row">
    <view class="hint-cell" wx:for="{{hintRadicals}}" wx:key="index">
      <text wx:if="{{item !== '?'}}" class="hint-char hint-{{hintPositions[index] || 'center'}}">{{item}}</text>
      <text wx:else class="hint-q">?</text>
    </view>
  </view>

  <!-- 游戏网格：历史猜测 + 空行 -->
  <view class="grid">
    <!-- 已完成的猜测行 -->
    <view class="grid-row {{status === 'won' && index === attempts.length - 1 ? 'win-row' : ''}}" wx:for="{{attempts}}" wx:key="index">
      <view
        class="char-cell {{cell.color}}"
        wx:for="{{item.result.chars}}"
        wx:for-item="cell"
        wx:key="index"
      >
        <text class="char-text">{{cell.char}}</text>
        <text class="pinyin-text">{{cell.pinyin || ''}}</text>
        <text class="status-label">{{cell.label}}</text>
      </view>
    </view>

    <!-- 空行（剩余尝试机会） -->
    <view
      class="grid-row empty-row"
      wx:for="{{maxAttempts - attempts.length}}"
      wx:key="index"
    >
      <view class="char-cell empty-cell" wx:for="{{inputSlots}}" wx:key="*this">
        <text class="char-text"></text>
      </view>
    </view>
  </view>

  <view class="round-feedback" wx:if="{{roundFeedback}}">
    <text>{{roundFeedback}}</text>
  </view>

  <!-- 提示系统 -->
  <view class="hint-section" wx:if="{{status === 'playing' && attempts.length >= 1}}">
    <view class="hint-toggle" bindtap="onRequestHint" wx:if="{{!showHint}}">
      <text>需要提示？</text>
    </view>
    <view class="hint-messages" wx:if="{{showHint && hintMessages.length > 0}}">
      <text class="hint-msg" wx:for="{{hintMessages}}" wx:key="index">{{item}}</text>
    </view>
  </view>

  <!-- 输入区 -->
  <view class="input-area" wx:if="{{status === 'playing' && gameReady}}">
    <!-- 4 个展示格 -->
    <view class="input-boxes" bindtap="onTapInputArea">
      <view
        class="input-char-box {{inputChars[index] ? 'has-char' : ''}} {{inputFocused ? 'active' : ''}}"
        wx:for="{{inputSlots}}"
        wx:key="*this"
      >
        <text class="input-char-text">{{inputChars[index] || ''}}</text>
        <view class="cursor-bar" wx:if="{{inputFocused && index === inputChars.length && index < 4}}"></view>
      </view>
    </view>
    <view class="input-guide" wx:if="{{!inputText && attempts.length === 0}}">
      <text>{{inputGuideText}}</text>
    </view>
    <!-- 输入状态提示 -->
    <view class="input-status" wx:if="{{inputStatus}}">
      <text class="input-status-text {{inputStatus}}">
        <block wx:if="{{inputStatus === 'valid'}}">常见成语，可以提交</block>
        <block wx:elif="{{inputStatus === 'loose'}}">词库里暂时没有，换个常见成语试试</block>
        <block wx:elif="{{inputStatus === 'duplicate'}}">这条猜过了，换个方向</block>
      </text>
    </view>
    <!-- 键盘输入层：保留原生 input 接收中文输入法，视觉上由上方 4 个格子承担 -->
    <input
      wx:if="{{keyboardReady}}"
      class="keyboard-input"
      type="text"
      focus="{{inputFocused}}"
      bindinput="onInputChange"
      bindfocus="onInputFocus"
      bindblur="onInputBlur"
      confirm-type="done"
      bindconfirm="onSubmitGuess"
      adjust-position="{{true}}"
      hold-keyboard="{{true}}"
      cursor-spacing="160"
    />
  </view>

  <!-- 操作按钮 -->
  <view class="actions" wx:if="{{status === 'playing' && gameReady}}">
    <button class="btn btn-clear" bindtap="onClearInput">
      清空
    </button>
    <button
      class="btn btn-submit {{canSubmit ? '' : 'disabled'}}"
      bindtap="onSubmitGuess"
      disabled="{{!canSubmit || submitting}}"
    >
      {{submitting ? '判定中' : '猜！'}}
    </button>
  </view>

  <!-- 胜利/失败提示 -->
  <view class="praise-overlay" wx:if="{{showPraise}}">
    <view class="praise-card">
      <view class="praise-emoji">{{status === 'won' ? '成' : '答'}}</view>
      <view class="praise-text">{{praiseText}}</view>

      <!-- 答案显示 -->
      <view class="answer-reveal" wx:if="{{showAnswer}}">
        <text class="answer-label">答案是：</text>
        <text class="answer-text">{{answerText}}</text>
        <text class="answer-pinyin">{{answerPinyin}}</text>
        <text class="answer-meaning">{{answerMeaning}}</text>
      </view>

      <!-- Emoji 战绩 -->
      <view class="emoji-grid" wx:if="{{attempts.length > 0}}">
        <text class="emoji-line" wx:for="{{attempts}}" wx:key="index">{{item.result.emojiString}}</text>
      </view>
      <view class="result-review" wx:if="{{resultReview}}">
        <text>{{resultReview}}</text>
      </view>

      <view class="compare-panel" wx:if="{{comparisonText && !practiceMode}}">
        <text class="compare-title">今日全网对比</text>
        <text class="compare-text">{{comparisonText}}</text>
        <view class="compare-bars">
          <view class="compare-row" wx:for="{{comparisonBars}}" wx:key="key">
            <text class="compare-label">{{item.label}}</text>
            <view class="compare-track">
              <view class="compare-fill" style="width: {{item.width}}%;"></view>
            </view>
            <text class="compare-count">{{item.count}}</text>
          </view>
        </view>
      </view>

      <view class="retention-panel" wx:if="{{!practiceMode}}">
        <view class="retention-copy">
          <text class="retention-title">明日新题</text>
          <text class="retention-text">订阅提醒，明天继续盖章。</text>
          <text class="retention-state" wx:if="{{reminderStatusText}}">{{reminderStatusText}}</text>
        </view>
        <button class="btn-mini" bindtap="onRequestReminder">提醒我</button>
      </view>

      <view class="retention-panel shield-panel" wx:if="{{!practiceMode}}">
        <view class="retention-copy">
          <text class="retention-title">{{shieldTitleText}}</text>
          <text class="retention-text">{{shieldDescText}}</text>
          <text class="retention-state" wx:if="{{shieldStatusText}}">{{shieldStatusText}}</text>
        </view>
        <button class="btn-mini btn-shield" bindtap="onClaimShield" disabled="{{shieldLoading}}">{{shieldActionText}}</button>
      </view>

      <!-- 分享按钮 -->
      <button class="btn btn-share" open-type="share">
        找朋友来比试比试
      </button>

      <!-- 返回首页 -->
      <view class="btn-back-home" bindtap="onNavHome">
        返回首页
      </view>

      <!-- 练习模式：换一题按钮 -->
      <button class="btn btn-share" wx:if="{{practiceMode}}" bindtap="onNewPractice">
        换一题
      </button>

      <!-- 连击提示 -->
      <view class="streak-badge" wx:if="{{streakDays >= 3 && !practiceMode}}">
        连击 {{streakDays}} 天
      </view>
    </view>
  </view>

  <view class="first-guide-overlay" wx:if="{{showFirstGuide}}" bindtap="onCloseFirstGuide">
    <view class="first-guide-card" catchtap="onStopGuideTap">
      <view class="first-guide-head">
        <text class="first-guide-kicker">新手开局</text>
        <text class="first-guide-title">三步读懂部首猜词</text>
      </view>
      <view class="first-guide-list">
        <view class="first-guide-item" wx:for="{{firstGuideSteps}}" wx:key="key">
          <text class="first-guide-mark">{{index + 1}}</text>
          <view class="first-guide-copy">
            <text class="first-guide-item-title">{{item.title}}</text>
            <text class="first-guide-item-text">{{item.text}}</text>
          </view>
        </view>
      </view>
      <button class="btn-guide-start" bindtap="onCloseFirstGuide">开始破题</button>
    </view>
  </view>

  <canvas canvas-id="shareCanvas" class="share-canvas"></canvas>
  <!-- 底部导航 -->
  <view class="tab-bar">
    <view class="tab-item" bindtap="onNavHome">
      <text class="tab-icon">首</text>
      <text class="tab-text">首页</text>
    </view>
    <view class="tab-item" bindtap="onGoRank">
      <text class="tab-icon">榜</text>
      <text class="tab-text">印记</text>
    </view>
    <view class="tab-item" bindtap="onGoProfile">
      <text class="tab-icon">我</text>
      <text class="tab-text">我的</text>
    </view>
  </view>

</view>
