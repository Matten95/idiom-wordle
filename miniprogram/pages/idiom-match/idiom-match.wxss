.page {
  min-height: 100vh;
  padding: calc(72rpx + env(safe-area-inset-top)) 30rpx 42rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 14% 8%, rgba(255, 218, 142, 0.55) 0, rgba(255, 218, 142, 0) 190rpx),
    radial-gradient(circle at 88% 10%, rgba(108, 167, 225, 0.42) 0, rgba(108, 167, 225, 0) 210rpx),
    linear-gradient(180deg, #eaf4ff 0%, #f8efe0 54%, #eaf2ff 100%);
  color: #18213d;
}

.header {
  position: relative;
  display: flex;
  align-items: center;
  width: 100%;
  max-width: 650rpx;
  min-height: 104rpx;
  margin: 0 auto 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  background: rgba(30, 75, 135, 0.16);
  box-shadow: 0 12rpx 30rpx rgba(26, 63, 120, 0.1);
  box-sizing: border-box;
}

.header-back {
  flex: 1;
  color: #315fb5;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.2;
}

.header-title {
  flex: 1;
  color: #18213d;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.2;
  text-align: center;
  letter-spacing: 0;
}

.header-spacer {
  flex: 1;
}

.timer-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 18rpx;
}

.timer-ring {
  width: 116rpx;
  height: 116rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.86);
  background: linear-gradient(135deg, #315fb5 0%, #f0a641 100%);
  box-shadow: 0 14rpx 28rpx rgba(28, 57, 112, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  transition: border-color 0.3s;
}

.timer-ring.urgent {
  border-color: #e45b58;
  animation: pulse 0.5s infinite;
}

.timer-text {
  color: #ffffff;
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1;
}

.timer-ring.urgent .timer-text {
  color: #e45b58;
}

.timer-label {
  margin-top: 6rpx;
  color: #9a621e;
  font-size: 22rpx;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.story-card {
  position: relative;
  width: 100%;
  max-width: 650rpx;
  margin: 0 auto 20rpx;
  padding: 30rpx 28rpx 30rpx;
  border-radius: 24rpx;
  overflow: hidden;
  border: 2rpx solid rgba(240, 166, 65, 0.28);
  background: linear-gradient(180deg, rgba(255, 252, 242, 0.98) 0%, rgba(255, 238, 202, 0.98) 100%);
  box-shadow: 0 22rpx 46rpx rgba(151, 97, 28, 0.16);
  box-sizing: border-box;
}

.story-card::before {
  content: '';
  position: absolute;
  top: -48rpx;
  right: -36rpx;
  width: 188rpx;
  height: 188rpx;
  border-radius: 50%;
  background: rgba(228, 91, 88, 0.08);
}

.story-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin: 0 0 16rpx;
}

.story-tag {
  max-width: 100%;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  color: #9a621e;
  background: rgba(255, 246, 223, 0.92);
  border: 1rpx solid rgba(240, 166, 65, 0.22);
  font-size: 22rpx;
  line-height: 1.2;
  box-sizing: border-box;
}

.story-tag.ghost {
  color: #23856d;
  background: rgba(238, 248, 245, 0.92);
  border-color: rgba(35, 133, 109, 0.2);
}

.story-tag.source {
  color: #315fb5;
  background: rgba(237, 243, 255, 0.92);
  border-color: rgba(39, 76, 150, 0.2);
}

.story-hook {
  position: relative;
  z-index: 1;
  display: block;
  color: #18213d;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.55;
}

.story-lock {
  position: relative;
  z-index: 1;
  padding: 18rpx;
  border-radius: 18rpx;
  border: 2rpx dashed rgba(240, 166, 65, 0.34);
  background: rgba(255, 255, 255, 0.5);
  box-sizing: border-box;
}

.story-lock-title {
  display: block;
  color: #18213d;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.25;
}

.story-lock-text {
  display: block;
  margin-top: 8rpx;
  color: #59647a;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.45;
}

.btn-story-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  margin-top: 18rpx;
  padding: 0 24rpx;
  border-radius: 18rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #e45b58 0%, #f0a641 100%);
  box-shadow: 0 12rpx 24rpx rgba(228, 91, 88, 0.16);
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.2;
  box-sizing: border-box;
}

.btn-story-hint.loading {
  opacity: 0.72;
}

.btn-story-hint:active {
  opacity: 0.86;
  transform: translateY(2rpx);
}

.hints-area {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  justify-content: center;
  width: 100%;
  max-width: 650rpx;
  margin: 0 auto 16rpx;
}

.hint-card {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 118rpx;
  min-height: 76rpx;
  padding: 16rpx 22rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(55, 86, 152, 0.18);
  background: rgba(255, 255, 255, 0.74);
  box-shadow: 0 10rpx 22rpx rgba(28, 57, 112, 0.07);
  text-align: center;
  box-sizing: border-box;
  transition: all 0.25s;
}

.hint-card.visible {
  border-color: rgba(240, 166, 65, 0.34);
  background: #fff9ee;
}

.hint-card.current {
  border-color: rgba(228, 91, 88, 0.46);
  background: linear-gradient(180deg, #ffffff 0%, #fff3d7 100%);
  box-shadow: 0 14rpx 28rpx rgba(228, 91, 88, 0.12);
}

.hint-card.hidden {
  border-style: dashed;
  opacity: 0.68;
}

.hint-word {
  display: block;
  color: #315fb5;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.2;
}

.hint-card.hidden .hint-word {
  color: rgba(89, 100, 122, 0.48);
}

.progress {
  margin-bottom: 14rpx;
  text-align: center;
}

.progress-text {
  color: #59647a;
  font-size: 24rpx;
  line-height: 1.2;
}

.progress-dots {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-top: 10rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: rgba(89, 100, 122, 0.28);
  transition: background 0.3s;
}

.dot.done {
  background: linear-gradient(135deg, #e45b58 0%, #f0a641 100%);
}

.skip-section {
  width: 100%;
  max-width: 650rpx;
  margin: 0 auto 16rpx;
}

.btn-skip {
  padding: 16rpx 20rpx;
  border-radius: 18rpx;
  border: 2rpx solid rgba(240, 166, 65, 0.6);
  color: #9a621e;
  background: rgba(255, 246, 217, 0.78);
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.2;
  text-align: center;
  box-sizing: border-box;
  transition: all 0.25s;
}

.btn-skip.early {
  border-color: rgba(228, 91, 88, 0.46);
  color: #a74338;
  background: rgba(255, 238, 218, 0.86);
}

.btn-skip.free {
  border-color: rgba(35, 133, 109, 0.36);
  color: #23856d;
  background: rgba(232, 248, 240, 0.88);
}

.btn-skip:active {
  opacity: 0.86;
  transform: translateY(2rpx);
}

.skip-hint {
  display: block;
  margin-top: 8rpx;
  color: #59647a;
  font-size: 22rpx;
  line-height: 1.3;
  text-align: center;
}

.score-rule {
  display: block;
  margin-top: 8rpx;
  color: rgba(24, 33, 61, 0.58);
  font-size: 21rpx;
  line-height: 1.3;
  text-align: center;
}

.input-section {
  width: 100%;
  max-width: 650rpx;
  margin: 0 auto;
  position: relative;
}

.input-boxes {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.input-char-box {
  width: 112rpx;
  height: 112rpx;
  border-radius: 18rpx;
  border: 3rpx dashed rgba(49, 95, 181, 0.42);
  background: rgba(255, 255, 255, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.input-char-box.has-char {
  border-style: solid;
  border-color: rgba(49, 95, 181, 0.58);
  background: #ffffff;
}

.input-char-box.active {
  border-color: rgba(240, 166, 65, 0.72);
  box-shadow: inset 0 0 0 5rpx rgba(240, 166, 65, 0.08);
}

.input-char-text {
  color: #18213d;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1;
}

.input-status {
  margin-bottom: 8rpx;
  text-align: center;
}

.input-status-text {
  padding: 5rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.2;
}

.input-status-text.valid {
  color: #315fb5;
  background: #edf3ff;
}

.input-status-text.loose {
  color: #9a621e;
  background: #fff3d7;
}

.guess-assist {
  margin: 0 auto 10rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  color: #9a621e;
  background: rgba(255, 246, 217, 0.78);
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.35;
  text-align: center;
  box-sizing: border-box;
}

.keyboard-input {
  position: absolute;
  left: 50%;
  top: 0;
  width: 2rpx;
  height: 2rpx;
  opacity: 0;
}

.actions {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.btn {
  flex: 1;
  min-height: 82rpx;
  padding: 0;
  border-radius: 999rpx;
  font-size: 30rpx;
  line-height: 82rpx;
  text-align: center;
  border: none;
  box-sizing: border-box;
}

.btn::after {
  border: none;
}

.btn:active {
  opacity: 0.86;
  transform: translateY(2rpx);
}

.btn-submit {
  flex: 2;
  background: linear-gradient(135deg, #e45b58 0%, #f0a641 100%);
  color: #ffffff;
  font-weight: 900;
  box-shadow: 0 16rpx 30rpx rgba(228, 91, 88, 0.22);
}

.btn-submit.disabled {
  background: rgba(89, 100, 122, 0.2);
  color: rgba(89, 100, 122, 0.56);
  box-shadow: none;
}

.btn-clear {
  background: rgba(255, 255, 255, 0.54);
  border: 1rpx solid rgba(55, 86, 152, 0.22);
  color: #59647a;
}

.result-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  padding: 40rpx;
  background: rgba(28, 57, 112, 0.58);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.result-card {
  width: 100%;
  max-width: 560rpx;
  padding: 44rpx 36rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(240, 166, 65, 0.28);
  background: linear-gradient(180deg, rgba(255, 252, 242, 0.98) 0%, rgba(255, 238, 202, 0.98) 100%);
  box-shadow: 0 24rpx 62rpx rgba(151, 97, 28, 0.22);
  text-align: center;
  box-sizing: border-box;
  animation: slideUp 0.4s ease;
}

@keyframes slideUp {
  from { transform: translateY(80rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.result-emoji {
  margin-bottom: 10rpx;
  font-size: 72rpx;
  line-height: 1;
}

.result-burst {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 58rpx;
  margin-bottom: 12rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #e45b58 0%, #f0a641 100%);
  box-shadow: 0 14rpx 26rpx rgba(228, 91, 88, 0.2);
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.2;
  animation: scorePop 0.42s ease;
}

.result-title {
  margin-bottom: 10rpx;
  color: #18213d;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.2;
}

.result-score {
  margin: 14rpx 0;
}

.score-num {
  color: #18213d;
  font-size: 70rpx;
  font-weight: 700;
  line-height: 1;
  animation: scorePop 0.42s ease;
}

.score-label {
  margin-left: 6rpx;
  color: #59647a;
  font-size: 28rpx;
}

.score-breakdown {
  display: inline-block;
  max-width: 100%;
  margin: 0 auto 12rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #9a621e;
  background: rgba(255, 246, 223, 0.86);
  border: 1rpx solid rgba(240, 166, 65, 0.24);
  font-size: 22rpx;
  line-height: 1.35;
  box-sizing: border-box;
}

.result-reward {
  display: inline-block;
  max-width: 100%;
  margin: 0 auto 12rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  color: #9a621e;
  background: rgba(255, 246, 217, 0.86);
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1.25;
  box-sizing: border-box;
}

.result-answer {
  margin: 16rpx 0;
  padding: 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.68);
  box-sizing: border-box;
}

.answer-label {
  color: #59647a;
  font-size: 26rpx;
}

.answer-text {
  display: block;
  margin-top: 6rpx;
  color: #315fb5;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.2;
  letter-spacing: 0;
}

.result-story {
  margin: 12rpx 0;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 246, 217, 0.72);
  text-align: left;
  box-sizing: border-box;
}

.result-story-title {
  display: block;
  margin-bottom: 6rpx;
  color: #9a621e;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1.25;
}

.result-story-text {
  display: block;
  color: #59647a;
  font-size: 24rpx;
  line-height: 1.45;
}

.result-hints {
  margin: 10rpx 0;
  text-align: left;
}

.hint-chain-title {
  display: block;
  margin-bottom: 6rpx;
  color: #59647a;
  font-size: 24rpx;
}

.hint-chain-item {
  display: inline-block;
  margin-right: 12rpx;
  color: #315fb5;
  font-size: 24rpx;
  line-height: 1.5;
}

.btn-again {
  width: 100%;
  margin-top: 20rpx;
  background: linear-gradient(135deg, #e45b58 0%, #f0a641 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 900;
  box-shadow: 0 16rpx 30rpx rgba(228, 91, 88, 0.2);
}

.btn-share {
  width: 100%;
  margin-top: 12rpx;
  background: rgba(255, 255, 255, 0.62);
  color: #315fb5;
  border: 1rpx solid rgba(49, 95, 181, 0.24);
  font-size: 32rpx;
}

.btn-back {
  display: inline-block;
  padding: 12rpx 18rpx;
  margin-top: 16rpx;
  color: #59647a;
  font-size: 26rpx;
  line-height: 1.2;
  border-radius: 999rpx;
}

.btn-back:active {
  background: rgba(89, 100, 122, 0.12);
  opacity: 0.82;
}

@keyframes scorePop {
  0% { transform: scale(0.86); opacity: 0.62; }
  70% { transform: scale(1.06); opacity: 1; }
  100% { transform: scale(1); opacity: 1; }
}
