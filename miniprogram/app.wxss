/* 全局样式 — 白玉靛蓝主题 */
page {
  background-color: #F1F5FF;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  color: #18213d;
  font-size: 16px;
}

/* 反馈色（字形 / 拼音 / 含字 / 部件 / 无匹配） */
.correct  { background-color: #23856d; color: #ffffff; }
.pinyin   { background-color: #315fb5; color: #ffffff; }
.present  { background-color: #d88c2e; color: #ffffff; }
.partial  { background-color: #7a67b7; color: #ffffff; }
.absent   { background-color: #8b93a1; color: #ffffff; }

/* 浅色文字版（用于拼音行） */
.correct-light  { color: #23856d; }
.pinyin-light   { color: #315fb5; }
.present-light  { color: #9a621e; }
.partial-light  { color: #6d5da3; }
.absent-light   { color: #59647a; }

/* 通用按钮 */
.btn-primary {
  background: linear-gradient(135deg, #315fb5 0%, #5f73c7 100%);
  color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 32rpx;
  text-align: center;
  border: none;
}
.btn-primary:active {
  opacity: 0.8;
}
.btn-primary[disabled] {
  background: rgba(237, 243, 255, 0.86);
  color: rgba(49, 95, 181, 0.42);
  border: 1rpx solid rgba(49, 95, 181, 0.14);
}

/* 通用卡片 */
.card {
  background-color: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(55, 86, 152, 0.16);
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 10rpx 28rpx rgba(28, 57, 112, 0.08);
}

/* ========== 底部导航栏（全局） ========== */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(55, 86, 152, 0.16);
  padding: 14rpx 0;
  padding-bottom: calc(14rpx + env(safe-area-inset-bottom));
  z-index: 50;
  box-shadow: 0 -8rpx 24rpx rgba(28, 57, 112, 0.08);
}
.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 6rpx 32rpx;
  transition: all 0.2s;
  position: relative;
  min-width: 100rpx;
}
.tab-item:active {
  transform: scale(0.95);
}
.tab-item.active::before {
  content: '';
  position: absolute;
  top: -15rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #315fb5 0%, #5f73c7 100%);
  border-radius: 2rpx;
}
.tab-icon {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(89, 100, 122, 0.28);
  color: #59647a;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
  margin-bottom: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s;
}
.tab-item.active .tab-icon {
  transform: translateY(-2rpx);
  color: #ffffff;
  background: linear-gradient(135deg, #315fb5 0%, #5f73c7 100%);
  border-color: #315fb5;
}
.tab-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #59647a;
  transition: color 0.2s;
}
.tab-item.active .tab-text {
  color: #315fb5;
  font-weight: 600;
}

/* 全局动画 */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.fade-in-up {
  animation: fadeInUp 0.4s ease;
}
